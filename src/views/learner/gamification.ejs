<!-- Learner Gamification Dashboard -->
<style>
    .xp-banner {
        background: linear-gradient(135deg, rgba(245, 197, 24, 0.12), rgba(245, 197, 24, 0.04));
        border: 1px solid rgba(245, 197, 24, 0.2);
        border-radius: 16px;
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .xp-ring {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: conic-gradient(#F5C518 <%=(user.points || 0) % 100 %>%, rgba(255, 255, 255, 0.05) 0);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        position: relative;
    }

    .xp-ring::after {
        content: '';
        position: absolute;
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: #0E0E0E;
    }

    .xp-level {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.8rem;
        color: #F5C518;
        z-index: 1;
    }

    .xp-total {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 3rem;
        color: #F5C518;
    }

    .section-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
    }

    .section-head h3 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #fff;
    }

    .badges-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .badge-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 14px;
        padding: 1.5rem 1rem;
        text-align: center;
        transition: all 0.3s;
    }

    .badge-card.earned {
        border-color: rgba(245, 197, 24, 0.3);
        background: rgba(245, 197, 24, 0.05);
    }

    .badge-card:hover {
        transform: translateY(-4px);
    }

    .badge-emoji {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        display: block;
    }

    .badge-name {
        font-size: 0.8rem;
        font-weight: 700;
        color: #fff;
    }

    .badge-desc {
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.3);
        margin-top: 0.25rem;
    }

    .badge-locked {
        filter: grayscale(1);
        opacity: 0.3;
    }

    .leaderboard-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 12px;
        margin-bottom: 0.75rem;
        transition: all 0.2s;
    }

    .leaderboard-item:hover {
        border-color: rgba(245, 197, 24, 0.15);
    }

    .lb-rank {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.3rem;
        color: rgba(255, 255, 255, 0.2);
        width: 30px;
    }

    .lb-rank.gold {
        color: #F5C518;
    }

    .lb-rank.silver {
        color: #A0A0A0;
    }

    .lb-rank.bronze {
        color: #CD7F32;
    }

    .lb-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #333, #111);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .lb-name {
        flex: 1;
        font-weight: 600;
        color: #fff;
        font-size: 0.9rem;
    }

    .lb-you {
        font-size: 0.7rem;
        color: #F5C518;
        margin-left: 6px;
        font-weight: 700;
    }

    .lb-points {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.3rem;
        color: #F5C518;
    }
</style>

<!-- XP Banner -->
<div class="xp-banner">
    <div class="xp-ring">
        <span class="xp-level">LV<%= Math.floor((user.points||0)/100)+1 %></span>
    </div>
    <div style="flex:1;">
        <p
            style="color:rgba(255,255,255,0.4); font-size:0.8rem; text-transform:uppercase; letter-spacing:2px; margin-bottom:0.25rem;">
            Total XP Earned</p>
        <div style="display:flex; align-items:baseline; gap:0.75rem;">
            <span class="xp-total">
                <%= user.points || 0 %>
            </span>
            <span style="color:rgba(255,255,255,0.3); font-size:0.9rem;">points</span>
        </div>
        <div style="margin-top:1rem;">
            <div
                style="display:flex; justify-content:space-between; font-size:0.78rem; color:rgba(255,255,255,0.35); margin-bottom:6px;">
                <span>Progress to Level <%= Math.floor((user.points||0)/100)+2 %></span>
                <span>
                    <%= (user.points||0) % 100 %>/100 XP
                </span>
            </div>
            <div style="height:6px; background:rgba(255,255,255,0.06); border-radius:3px; overflow:hidden;">
                <div
                    style="height:100%; width:<%= (user.points||0) % 100 %>%; background:linear-gradient(90deg,#F5C518,#FFD700); box-shadow:0 0 10px rgba(245,197,24,0.5); border-radius:3px; transition:width 1s ease;">
                </div>
            </div>
        </div>
    </div>
    <div style="text-align:center; padding-left:2rem; border-left:1px solid rgba(255,255,255,0.06);">
        <div style="font-family:'Bebas Neue',sans-serif; font-size:2.5rem; color:#F5C518;">
            <%= badges.filter(b=>b.earned).length || 0 %>
        </div>
        <div style="font-size:0.75rem; color:rgba(255,255,255,0.3); text-transform:uppercase; letter-spacing:1.5px;">
            Badges Earned</div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1.5fr 1fr; gap:2rem;">
    <!-- Left: Badges -->
    <div>
        <div class="section-head">
            <h3>🏅 Achievement Badges</h3>
        </div>
        <div class="badges-grid">
            <% const allBadges=[ { name:'First Step', emoji:'👣', desc:'Complete your first lesson',
                threshold:'lesson_1' }, { name:'Quiz Ace', emoji:'🎯', desc:'Score 100% on a quiz', threshold:'quiz_100'
                }, { name:'On Fire', emoji:'🔥', desc:'7-day learning streak', threshold:'streak_7' }, {
                name:'Graduate', emoji:'🎓', desc:'Complete first course', threshold:'course_1' }, { name:'Centurion',
                emoji:'💯', desc:'Earn 100 XP points', threshold:'xp_100' }, { name:'Social', emoji:'🤝', desc:'Leave a
                course review', threshold:'review_1' }, { name:'Speedrun', emoji:'⚡', desc:'Complete a course in 24h',
                threshold:'speed_1' }, { name:'Legend', emoji:'👑', desc:'Top 3 on leaderboard', threshold:'lb_top3' },
                ]; %>
                <% allBadges.forEach(function(b) { const isEarned=badges && badges.some && badges.some(ub=> ub.badge &&
                    ub.badge.name === b.name);
                    %>
                    <div class="badge-card <%= isEarned ? 'earned' : '' %>">
                        <span class="badge-emoji <%= isEarned ? '' : 'badge-locked' %>">
                            <%= b.emoji %>
                        </span>
                        <div class="badge-name">
                            <%= b.name %>
                        </div>
                        <div class="badge-desc">
                            <%= b.desc %>
                        </div>
                        <% if (isEarned) { %>
                            <div style="margin-top:0.5rem; font-size:0.65rem; color:#F5C518; font-weight:700;">EARNED ✓
                            </div>
                            <% } %>
                    </div>
                    <% }); %>
        </div>
    </div>

    <!-- Right: Leaderboard -->
    <div>
        <div class="section-head">
            <h3>🏆 Leaderboard</h3>
            <span style="font-size:0.78rem; color:rgba(255,255,255,0.3);">Top Learners</span>
        </div>
        <% const lbData=leaders && leaders.length ? leaders : [ { name:'Alex Kim', points:920, isYou:false }, {
            name:'Priya Shah', points:810, isYou:false }, { name:'Marco L.', points:640, isYou:false }, { name:'You',
            points: user.points||0, isYou:true }, { name:'Jordan T.', points:390, isYou:false }, ]; %>
            <% lbData.slice(0,10).forEach(function(p, i) { %>
                <div class="leaderboard-item"
                    style="<%= p.isYou ? 'border-color:rgba(245,197,24,0.3); background:rgba(245,197,24,0.04);' : '' %>">
                    <span class="lb-rank <%= i===0?'gold':i===1?'silver':i===2?'bronze':'' %>">
                        <%= i+1 %>
                    </span>
                    <div class="lb-avatar">
                        <%= p.name.charAt(0) %>
                    </div>
                    <span class="lb-name">
                        <%= p.name %>
                            <%= p.isYou ? '<span class="lb-you">YOU</span>' : '' %>
                    </span>
                    <span class="lb-points">
                        <%= p.points %> XP
                    </span>
                </div>
                <% }); %>
    </div>
</div>