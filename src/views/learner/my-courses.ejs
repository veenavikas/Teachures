<!-- Learner My Courses -->
<style>
    .my-courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 1.25rem;
    }

    .my-course-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 14px;
        overflow: hidden;
        transition: all 0.3s;
    }

    .my-course-card:hover {
        border-color: rgba(245, 197, 24, 0.25);
        transform: translateY(-4px);
    }

    .my-course-thumb {
        height: 140px;
        background: linear-gradient(135deg, #1a1a2e, #0f0f1a);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .my-course-thumb svg {
        width: 40px;
        height: 40px;
        color: rgba(245, 197, 24, 0.2);
    }

    .my-course-body {
        padding: 1.25rem;
    }

    .my-course-title {
        font-weight: 700;
        color: #fff;
        font-size: 0.95rem;
        line-height: 1.4;
        margin-bottom: 0.5rem;
    }

    .my-course-trainer {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.3);
        margin-bottom: 1rem;
    }

    .pct-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        margin-bottom: 5px;
    }

    .pct-track {
        height: 5px;
        background: rgba(255, 255, 255, 0.07);
        border-radius: 3px;
        overflow: hidden;
    }

    .pct-fill {
        height: 100%;
        background: linear-gradient(90deg, #F5C518, #FFD700);
        border-radius: 3px;
    }

    .my-course-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .btn-continue {
        flex: 1;
        padding: 0.65rem;
        background: #F5C518;
        color: #000;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.82rem;
        cursor: pointer;
        text-decoration: none;
        text-align: center;
    }

    .btn-continue:hover {
        background: #D4AA00;
    }
</style>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.75rem;">
    <div>
        <h2 style="font-size:1.4rem; font-weight:700; color:#fff; margin-bottom:0.25rem;">My Learning</h2>
        <p style="color:rgba(255,255,255,0.3); font-size:0.88rem;">
            <%= courses.length %> course<%= courses.length !==1 ? 's' : '' %> enrolled
        </p>
    </div>
    <a href="/courses"
        style="padding:0.7rem 1.5rem; background:rgba(255,255,255,0.04); color:rgba(255,255,255,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:10px; font-size:0.85rem; font-weight:600; text-decoration:none; transition:all 0.2s;">Browse
        More Courses</a>
</div>

<% if (courses.length===0) { %>
    <div style="text-align:center; padding:5rem 2rem; color:rgba(255,255,255,0.2);">
        <i data-lucide="book-open"
            style="width:56px; height:56px; display:block; margin:0 auto 1.5rem; color:rgba(255,255,255,0.08);"></i>
        <h3 style="color:rgba(255,255,255,0.25); margin-bottom:0.5rem;">No courses yet</h3>
        <p style="margin-bottom:2rem;">Explore our catalog and start learning today.</p>
        <a href="/courses"
            style="display:inline-block; padding:0.85rem 2rem; background:linear-gradient(135deg,#F5C518,#D4AA00); color:#000; border-radius:10px; font-weight:700; text-decoration:none;">Browse
            Courses</a>
    </div>
    <% } else { %>
        <div class="my-courses-grid">
            <% courses.forEach(function(course) { %>
                <div class="my-course-card">
                    <div class="my-course-thumb">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                            stroke-width="1.5">
                            <polyline points="16 18 22 12 16 6" />
                            <polyline points="8 6 2 12 8 18" />
                        </svg>
                        <% if (Math.round(course.progress)>= 100) { %>
                            <span
                                style="position:absolute; top:10px; right:10px; background:rgba(16,185,129,0.9); color:#fff; font-size:0.7rem; font-weight:700; padding:3px 10px; border-radius:50px;">✓
                                COMPLETED</span>
                            <% } %>
                    </div>
                    <div class="my-course-body">
                        <div class="my-course-title">
                            <%= course.title %>
                        </div>
                        <div class="my-course-trainer">By <%= course.trainer ? course.trainer.name : 'Instructor' %>
                        </div>
                        <div class="pct-label">
                            <span style="color:rgba(255,255,255,0.35);">Progress</span>
                            <span
                                style="color:<%= Math.round(course.progress) >= 100 ? '#10B981' : '#F5C518' %>; font-weight:700;">
                                <%= Math.round(course.progress) %>%
                            </span>
                        </div>
                        <div class="pct-track">
                            <div class="pct-fill"
                                style="width:<%= Math.min(Math.round(course.progress),100) %>%; background:<%= Math.round(course.progress)>=100 ? 'linear-gradient(90deg,#10B981,#34D399)' : 'linear-gradient(90deg,#F5C518,#FFD700)' %>;">
                            </div>
                        </div>
                        <div class="my-course-actions">
                            <a href="/learner/courses/<%= course.slug %>/learn" class="btn-continue">
                                <%= Math.round(course.progress)>= 100 ? 'Review' : 'Continue' %> →
                            </a>
                        </div>
                    </div>
                </div>
                <% }); %>
        </div>
        <% } %>