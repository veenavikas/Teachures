<div class="header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h2>Manage Pages (CMS)</h2>
    <a href="/admin/pages/new" class="btn btn-primary">
        <i data-lucide="plus"></i> Create New Page
    </a>
</div>

<div class="card" style="padding: 0;">
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="border-bottom: 1px solid var(--color-gray-mid); background-color: var(--color-black);">
                <th style="padding: 1rem; text-align: left;">Title</th>
                <th style="padding: 1rem; text-align: left;">Slug</th>
                <th style="padding: 1rem; text-align: left;">Status</th>
                <th style="padding: 1rem; text-align: left;">Updated</th>
                <th style="padding: 1rem; text-align: right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (pages && pages.length > 0) { %>
                <% pages.forEach(page => { %>
                    <tr style="border-bottom: 1px solid var(--color-gray-mid);">
                        <td style="padding: 1rem;"><strong><%= page.title %></strong></td>
                        <td style="padding: 1rem;"><a href="/p/<%= page.slug %>" target="_blank" class="text-primary">/p/<%= page.slug %></a></td>
                        <td style="padding: 1rem;">
                            <% if (page.isDraft) { %>
                                <span class="badge" style="background: var(--color-gray-mid);">Draft</span>
                            <% } else { %>
                                <span class="badge" style="background: var(--color-success); color: var(--color-white);">Published</span>
                            <% } %>
                        </td>
                        <td style="padding: 1rem;"><%= new Date(page.updatedAt).toLocaleDateString() %></td>
                        <td style="padding: 1rem; text-align: right;">
                            <a href="/admin/pages/<%= page.id %>/edit" class="btn btn-outline" style="padding: 0.25rem 0.5rem;">Edit</a>
                            <button onclick="deletePage('<%= page.id %>')" class="btn btn-outline" style="padding: 0.25rem 0.5rem; color: var(--color-danger); border-color: var(--color-danger);">Delete</button>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="padding: 2rem; text-align: center; color: var(--color-muted);">No pages found. Create one!</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<script>
    async function deletePage(id) {
        if (!confirm('Are you sure you want to delete this page?')) return;
        try {
            const res = await fetch(`/api/v1/cms/${id}`, { method: 'DELETE' });
            if (res.ok) window.location.reload();
            else alert('Failed to delete page');
        } catch (err) {
            console.error(err);
            alert('Error deleting page');
        }
    }
</script>
