<div class="card" style="padding: 2rem;">
    <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem;">Platform Courses</h3>

    <% if (courses.length === 0) { %>
        <p class="text-muted">No courses found.</p>
    <% } else { %>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--color-gray-mid);">
                        <th style="padding: 1rem;">Course</th>
                        <th style="padding: 1rem;">Instructor</th>
                        <th style="padding: 1rem;">Stats</th>
                        <th style="padding: 1rem;">Status</th>
                        <th style="padding: 1rem;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% courses.forEach(course => { %>
                        <tr style="border-bottom: 1px solid var(--color-gray-mid);">
                            <td style="padding: 1rem; display: flex; align-items: center; gap: 10px;">
                                <% if (course.thumbnailUrl) { %>
                                    <img src="<%= course.thumbnailUrl %>" style="width: 60px; height: 40px; object-fit: cover; border-radius: 4px;">
                                <% } else { %>
                                    <div style="width: 60px; height: 40px; border-radius: 4px; background: var(--color-gray-dark); display: flex; align-items: center; justify-content: center; color: var(--color-gray-light);">
                                        <i data-lucide="video" class="icon-sm"></i>
                                    </div>
                                <% } %>
                                <div>
                                    <strong style="color: var(--color-white);"><%= course.title %></strong>
                                    <br>
                                    <small class="text-muted"><%= course.category %> • $<%= course.price %></small>
                                </div>
                            </td>
                            <td style="padding: 1rem;">
                                <%= course.instructor.name %><br>
                                <small class="text-muted"><%= course.instructor.email %></small>
                            </td>
                            <td style="padding: 1rem;">
                                <small style="display: block;">🎓 <%= course._count.enrollments %> Students</small>
                                <small style="display: block;">📚 <%= course.totalLessons %> Lessons</small>
                            </td>
                            <td style="padding: 1rem;">
                                <% if (course.isPublished) { %>
                                    <span style="background: rgba(var(--color-success-rgb), 0.1); color: var(--color-success); padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.85rem; font-weight: 600;">Published</span>
                                <% } else { %>
                                    <span style="background: rgba(var(--color-warning-rgb), 0.1); color: var(--color-warning); padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.85rem; font-weight: 600;">Draft</span>
                                <% } %>
                            </td>
                            <td style="padding: 1rem;">
                                <div style="display: flex; gap: 0.5rem;">
                                    <a href="/courses/<%= course.slug %>" target="_blank" class="btn btn-outline" style="padding: 0.4rem 0.6rem; font-size: 0.8rem;" title="View Public Page">
                                        <i data-lucide="external-link" class="icon-sm"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
