<div class="card" style="padding: 2rem; background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
    <h2 style="margin-bottom: 1.5rem; font-family: 'Inter', sans-serif; font-weight: 800; font-size: 1.5rem; color: var(--text-main); letter-spacing: -0.5px;">User Management</h2>
    <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead>
            <tr style="border-bottom: 2px solid var(--border-light); color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">
                <th style="padding: 1rem 0;">Name</th>
                <th style="padding: 1rem 0;">Email</th>
                <th style="padding: 1rem 0;">Role</th>
                <th style="padding: 1rem 0;">Actions</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(u => { %>
                <tr style="border-bottom: 1px solid var(--border-light);">
                    <td style="padding: 1rem 0; font-weight: 600; color: var(--text-main);"><%= u.name %></td>
                    <td style="padding: 1rem 0; color: var(--text-secondary);"><%= u.email %></td>
                    <td style="padding: 1rem 0;">
                        <span style="background: rgba(217, 119, 6, 0.1); color: #D97706; padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.5px;">
                            <%= u.role %>
                        </span>
                    </td>
                    <td style="padding: 1rem 0;">
                        <form action="/admin/users/<%= u.id %>/role" method="POST" style="display: flex; gap: 0.5rem; align-items: center;">
                            <select name="role" class="form-control" style="width: auto; padding: 0.5rem; font-size: 0.85rem; border-radius: 6px; border: 1px solid var(--border-light); background: var(--bg-offwhite); color: var(--text-main); font-weight: 500;">
                                <option value="STUDENT" <%= u.role === 'STUDENT' ? 'selected' : '' %>>Student</option>
                                <option value="INSTRUCTOR" <%= u.role === 'INSTRUCTOR' ? 'selected' : '' %>>Instructor</option>
                                <option value="ADMINISTRATOR" <%= u.role === 'ADMINISTRATOR' ? 'selected' : '' %>>Admin</option>
                            </select>
                            <button type="submit" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.85rem; border-radius: 6px; background: var(--yellow-gradient); color: var(--text-main); font-weight: 600; border: none; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 4px 10px rgba(217, 119, 6, 0.2)';" onmouseout="this.style.transform='none'; this.style.boxShadow='none';">Update</button>
                        </form>
                    </td>
                </tr>
            <% }); %>
            <% if (!users || users.length === 0) { %>
                <tr>
                    <td colspan="4" style="padding: 3rem 0; text-align: center; color: var(--text-secondary);">No users found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
