<div class="card" style="padding: 2rem; max-width: 800px; margin: 0 auto;">
    <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem;">Global Platform Settings</h3>

    <form action="/admin/settings" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group">
                <label class="form-label" style="font-weight: 600; color: var(--color-gray-dark);">Platform Name</label>
                <input type="text" name="platformName" class="form-control" value="<%= settings.platformName %>" required style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid);">
            </div>

            <div class="form-group">
                <label class="form-label" style="font-weight: 600; color: var(--color-gray-dark);">Support Email</label>
                <input type="email" name="supportEmail" class="form-control" value="<%= settings.supportEmail %>" required style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid);">
            </div>

            <div class="form-group">
                <label class="form-label" style="font-weight: 600; color: var(--color-gray-dark);">Platform Commission (%)</label>
                <input type="number" name="platformFeePercentage" class="form-control" value="<%= settings.platformFeePercentage %>" min="0" max="100" required style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid);">
                <small class="text-muted" style="display: block; margin-top: 0.4rem;">Percentage of each sale Teachures keeps.</small>
            </div>

            <div class="form-group">
                <label class="form-label" style="font-weight: 600; color: var(--color-gray-dark);">Currency Code</label>
                <input type="text" name="currency" class="form-control" value="<%= settings.currency %>" required style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid);">
            </div>
        </div>

        <div class="form-group" style="margin-top: 1.5rem;">
            <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; color: var(--color-gray-dark); cursor: pointer;">
                <input type="checkbox" name="allowPublicRegistration" <%= settings.allowPublicRegistration ? 'checked' : '' %> style="width: 18px; height: 18px;">
                Allow Public Instructor Registration
            </label>
            <small class="text-muted" style="display: block; margin-top: 0.4rem; margin-left: 1.8rem;">If unchecked, only admins can create instructor accounts manually.</small>
        </div>

        <hr style="border: 0; border-top: 1px solid rgba(0,0,0,0.1); margin: 2rem 0;">

        <div style="display: flex; justify-content: flex-end;">
            <button type="submit" class="btn btn-primary" style="padding: 0.75rem 2rem; font-weight: 600; border-radius: 8px;">Save Settings</button>
        </div>
    </form>
</div>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('success')) {
        // Simple mock success alert
        const div = document.createElement('div');
        div.style.cssText = 'background: rgba(var(--color-success-rgb), 0.1); color: var(--color-success); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; text-align: center; font-weight: 600;';
        div.innerText = 'Settings saved successfully!';
        document.querySelector('.card').prepend(div);
        
        // Remove param from url
        window.history.replaceState({}, document.title, window.location.pathname);
        setTimeout(() => div.remove(), 3000);
    }
</script>
