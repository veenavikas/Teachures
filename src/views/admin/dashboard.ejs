<div class="kpi-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 2.5rem;">
    <div class="card" style="padding: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="font-size: 1rem; color: var(--color-gray-light); margin:0;">Total Users</h3>
            <div style="padding: 0.5rem; background: rgba(245, 197, 24, 0.1); border-radius: 4px;"><i
                    data-lucide="users" class="text-primary icon-sm"></i></div>
        </div>
        <div style="font-size: 2rem; font-family: var(--font-display);">
            <%= stats.totalUsers || 0 %>
        </div>
        <div class="text-success" style="font-size: 0.85rem; margin-top: 0.5rem; font-weight: 500;"><i
                data-lucide="trending-up" class="icon-sm" style="vertical-align: middle;"></i> +8% this month</div>
    </div>

    <div class="card" style="padding: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="font-size: 1rem; color: var(--color-gray-light); margin:0;">Platform MRR</h3>
            <div style="padding: 0.5rem; background: rgba(245, 197, 24, 0.1); border-radius: 4px;"><i
                    data-lucide="dollar-sign" class="text-primary icon-sm"></i></div>
        </div>
        <div style="font-size: 2rem; font-family: var(--font-display);">$<%= stats.platformMRR || 0 %>
        </div>
        <div class="text-success" style="font-size: 0.85rem; margin-top: 0.5rem; font-weight: 500;"><i
                data-lucide="trending-up" class="icon-sm" style="vertical-align: middle;"></i> +15% this month</div>
    </div>

    <div class="card" style="padding: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="font-size: 1rem; color: var(--color-gray-light); margin:0;">Total Courses</h3>
            <div style="padding: 0.5rem; background: rgba(245, 197, 24, 0.1); border-radius: 4px;"><i
                    data-lucide="video" class="text-primary icon-sm"></i></div>
        </div>
        <div style="font-size: 2rem; font-family: var(--font-display);">
            <%= stats.totalCourses || 0 %>
        </div>
        <div class="text-muted" style="font-size: 0.85rem; margin-top: 0.5rem;">
            <%= stats.newCoursesThisWeek || 0 %> new this week
        </div>
    </div>

    <div class="card" style="padding: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="font-size: 1rem; color: var(--color-gray-light); margin:0;">Open Tickets</h3>
            <div style="padding: 0.5rem; background: rgba(229, 62, 62, 0.1); border-radius: 4px;"><i
                    data-lucide="alert-circle" class="text-danger icon-sm"></i></div>
        </div>
        <div style="font-size: 2rem; font-family: var(--font-display);">
            <%= stats.openTickets || 0 %>
        </div>
        <div class="text-danger" style="font-size: 0.85rem; margin-top: 0.5rem; font-weight: 500;">Requires attention
        </div>
    </div>
</div>

<div class="grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
    <!-- Revenue Chart -->
    <div class="card" style="padding: 1.5rem;">
        <h3
            style="font-size: 1.1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem;">
            Revenue (Last 30 Days)</h3>
        <div style="height: 300px; width: 100%; display: flex; align-items: center; justify-content: center;">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Role Distribution -->
    <div class="card" style="padding: 1.5rem;">
        <h3
            style="font-size: 1.1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem;">
            User Roles</h3>
        <div style="height: 300px; width: 100%; display: flex; align-items: center; justify-content: center;">
            <canvas id="rolesChart"></canvas>
            <script id="rolesData" type="application/json"><%- stats.roleDistribution || '[]' %></script>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Roles Chart
    const rolesData = JSON.parse(document.getElementById('rolesData').textContent);
    if(rolesData.length > 0 && document.getElementById('rolesChart')) {
        new Chart(document.getElementById('rolesChart'), {
            type: 'doughnut',
            data: {
                labels: rolesData.map(d => d.label),
                datasets: [{
                    data: rolesData.map(d => d.value),
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#ef4444']
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    }

    // Revenue Chart (Placeholder data but real implementation)
    if(document.getElementById('revenueChart')) {
        new Chart(document.getElementById('revenueChart'), {
            type: 'line',
            data: {
                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                datasets: [{
                    label: 'Revenue',
                    data: [1200, 1900, 3000, 2400], // To be fully dynamic later
                    borderColor: '#10b981',
                    tension: 0.1
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    }
});
</script>

<!-- Recent Enrollments Table -->
<div class="card" style="margin-top: 1.5rem; padding: 1.5rem;">
    <div
        style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem; margin-bottom: 1rem;">
        <h3 style="font-size: 1.1rem; margin: 0;">Recent Enrollments</h3>
        <a href="/admin/revenue" class="text-primary" style="font-size: 0.9rem;">View All</a>
    </div>

    <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead>
            <tr style="color: var(--color-gray-light); font-size: 0.85rem; text-transform: uppercase;">
                <th style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">Learner Name</th>
                <th style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">Course</th>
                <th style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">Date</th>
                <th style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">Amount</th>
                <th style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">Status</th>
            </tr>
        </thead>
        <tbody>
            <% if (recentEnrollments && recentEnrollments.length> 0) { %>
                <% recentEnrollments.forEach(enroll=> { %>
                    <tr>
                        <td style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">
                            <%= enroll.userName %>
                        </td>
                        <td style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">
                            <%= enroll.courseTitle %>
                        </td>
                        <td
                            style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid); color: var(--color-gray-light);">
                            <%= enroll.date %>
                        </td>
                        <td style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">$<%= enroll.amount
                                %>
                        </td>
                        <td style="padding: 1rem 0; border-bottom: 1px solid var(--color-gray-mid);">
                            <span
                                style="background: rgba(56, 161, 105, 0.1); color: var(--color-success); border: 1px solid rgba(56, 161, 105, 0.2); border-radius: 4px; padding: 4px 8px; font-size: 0.75rem; font-weight: 600;">
                                <%= enroll.status %>
                            </span>
                        </td>
                    </tr>
                    <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-muted text-center" style="padding: 2rem 0;">No recent
                                    enrollments.</td>
                            </tr>
                            <% } %>
        </tbody>
    </table>
</div>