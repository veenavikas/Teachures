<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' | Teachures' : 'Teachures | Authentication' %>
    </title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&family=Inter:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            background-color: #050505;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(245, 197, 24, 0.06), transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(245, 197, 24, 0.04), transparent 40%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            padding: 2rem;
            overflow-y: auto;
        }

        .auth-wrapper {
            display: flex;
            width: 100%;
            max-width: 960px;
            min-height: 620px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8), 0 0 0 1px rgba(255, 255, 255, 0.05);
            position: relative;
        }

        /* Back to home link */
        .back-home {
            position: fixed;
            top: 24px;
            left: 24px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.9rem;
            font-weight: 500;
            transition: color 0.2s;
            z-index: 100;
        }

        .back-home:hover {
            color: #F5C518;
            text-decoration: none;
        }

        .back-home svg {
            width: 18px;
            height: 18px;
        }

        /* Left Brand Panel */
        .auth-brand {
            flex: 1;
            background: linear-gradient(135deg, #111111 0%, #0D0D0D 100%);
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .auth-brand::before {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(245, 197, 24, 0.12) 0%, transparent 70%);
            bottom: -100px;
            right: -100px;
            pointer-events: none;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand-logo svg {
            width: 36px;
            height: 36px;
            color: #F5C518;
        }

        .brand-logo .wordmark {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.8rem;
            letter-spacing: 2px;
            color: #FFFFFF;
        }

        .brand-logo .wordmark span {
            color: #F5C518;
        }

        .brand-headline {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(2.5rem, 4vw, 3.5rem);
            line-height: 1;
            letter-spacing: 1px;
            color: #FFFFFF;
            margin-bottom: 1rem;
        }

        .brand-sub {
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.45);
            line-height: 1.7;
            max-width: 300px;
        }

        .brand-stats {
            display: flex;
            gap: 2rem;
        }

        .brand-stat-num {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            color: #F5C518;
            display: block;
        }

        .brand-stat-label {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.4);
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        /* Right Form Panel */
        .auth-form-panel {
            flex: 1;
            background: #0E0E0E;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow-y: auto;
        }

        .form-title {
            font-family: 'DM Sans', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: #FFFFFF;
            margin-bottom: 0.5rem;
        }

        .form-subtitle {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.4);
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.5);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
        }

        .form-control {
            width: 100%;
            padding: 0.85rem 1rem;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            color: #FFFFFF;
            transition: all 0.2s;
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.2);
        }

        .form-control:focus {
            outline: none;
            border-color: #F5C518;
            background: rgba(245, 197, 24, 0.04);
            box-shadow: 0 0 0 3px rgba(245, 197, 24, 0.1);
        }

        .btn-submit {
            width: 100%;
            padding: 0.9rem;
            background: linear-gradient(135deg, #F5C518 0%, #D4AA00 100%);
            color: #000000;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 0.5rem;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(245, 197, 24, 0.4);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.5rem 0;
            color: rgba(255, 255, 255, 0.2);
            font-size: 0.8rem;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255, 255, 255, 0.07);
        }

        .btn-google {
            width: 100%;
            padding: 0.85rem;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            color: #FFFFFF;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.2s;
        }

        .btn-google:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.15);
        }

        .form-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.35);
        }

        .form-footer a {
            color: #F5C518;
            font-weight: 600;
            text-decoration: none;
        }

        .form-footer a:hover {
            text-decoration: underline;
        }

        .icon-input {
            position: relative;
        }

        .icon-input svg {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            color: rgba(255, 255, 255, 0.2);
            pointer-events: none;
        }

        @media (max-width: 640px) {
            body {
                padding: 1rem;
            }

            .auth-wrapper {
                flex-direction: column;
                min-height: auto;
            }

            .auth-brand {
                padding: 2rem;
                min-height: 200px;
            }

            .brand-headline {
                font-size: 2rem;
            }

            .auth-form-panel {
                padding: 2rem;
            }
        }
    </style>
</head>

<body>

    <a href="/" class="back-home">
        <i data-lucide="arrow-left"></i> Back to home
    </a>

    <div class="auth-wrapper">
        <!-- Left brand panel -->
        <div class="auth-brand">
            <div class="brand-logo">
                <i data-lucide="graduation-cap"></i>
                <span class="wordmark">TEACH<span>URES</span></span>
            </div>

            <div>
                <h2 class="brand-headline">Learn Without Limits.</h2>
                <p class="brand-sub">Join thousands of students mastering new skills with world-class instructors.</p>
            </div>

            <div class="brand-stats">
                <div>
                    <span class="brand-stat-num">12K+</span>
                    <span class="brand-stat-label">Learners</span>
                </div>
                <div>
                    <span class="brand-stat-num">400+</span>
                    <span class="brand-stat-label">Courses</span>
                </div>
                <div>
                    <span class="brand-stat-num">95%</span>
                    <span class="brand-stat-label">Completion</span>
                </div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-form-panel">
            <%- body %>
        </div>
    </div>

    <script>lucide.createIcons();</script>
</body>

</html>