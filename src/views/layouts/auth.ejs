<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' | Teachures' : 'Teachures | Authentication' %>
    </title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css?v=lighttheme1">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            --yellow: #FFC107;
            --yellow-gradient: linear-gradient(135deg, #FFD54F, #FF8F00);
            --bg-white: #FFFFFF;
            --bg-offwhite: #F8FAFC;
            --text-main: #0F172A;
            --text-secondary: #475569;
            --border-light: #E2E8F0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            background-color: var(--bg-offwhite);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            padding: 2rem;
            overflow-y: auto;
        }

        .auth-wrapper {
            display: flex;
            width: 100%;
            max-width: 1000px;
            min-height: 650px;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0,0,0,0.02);
            position: relative;
            background: var(--bg-white);
        }

        /* Back to home link */
        .back-home {
            position: fixed;
            top: 24px;
            left: 24px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-secondary);
            font-size: 0.95rem;
            font-weight: 600;
            transition: color 0.2s;
            z-index: 100;
            text-decoration: none;
        }

        .back-home:hover {
            color: #D97706;
        }

        .back-home svg {
            width: 20px;
            height: 20px;
        }

        /* Left Brand Panel */
        .auth-brand {
            flex: 1;
            background: var(--bg-offwhite);
            border-right: 1px solid var(--border-light);
            padding: 4rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--text-main);
        }

        .brand-logo .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--yellow-gradient);
            border-radius: 8px;
        }

        .brand-headline {
            font-family: 'Inter', sans-serif;
            font-size: clamp(2.5rem, 4vw, 3.5rem);
            font-weight: 800;
            line-height: 1.1;
            letter-spacing: -1px;
            color: var(--text-main);
            margin-bottom: 1rem;
        }

        .brand-sub {
            font-size: 1.1rem;
            color: var(--text-secondary);
            line-height: 1.6;
            max-width: 320px;
        }

        .brand-stats {
            display: flex;
            gap: 2.5rem;
        }

        .brand-stat-num {
            font-weight: 800;
            font-size: 2rem;
            color: var(--text-main);
            display: block;
        }

        .brand-stat-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }

        /* Right Form Panel */
        .auth-form-panel {
            flex: 1;
            background: var(--bg-white);
            padding: 4rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow-y: auto;
        }

        .form-title {
            font-family: 'Inter', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .form-subtitle {
            font-size: 1rem;
            color: var(--text-secondary);
            margin-bottom: 2.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .form-control {
            width: 100%;
            padding: 1rem 1.25rem;
            background: var(--bg-offwhite);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            color: var(--text-main);
            transition: all 0.2s;
            outline: none;
        }

        .form-control::placeholder {
            color: #94A3B8;
        }

        .form-control:focus {
            border-color: #D97706;
            background: var(--bg-white);
            box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.1);
        }

        .btn-submit {
            width: 100%;
            padding: 1rem;
            background: var(--yellow-gradient);
            color: white;
            border: none;
            border-radius: 50px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 1rem;
            box-shadow: 0 4px 10px rgba(255, 193, 7, 0.3);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(255, 193, 7, 0.4);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 2rem 0;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border-light);
        }

        .btn-google {
            width: 100%;
            padding: 1rem;
            background: var(--bg-white);
            border: 1px solid var(--border-light);
            border-radius: 50px;
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-google:hover {
            background: var(--bg-offwhite);
            border-color: #CBD5E1;
        }

        .form-footer {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.95rem;
            color: var(--text-secondary);
        }

        .form-footer a {
            color: #D97706;
            font-weight: 700;
            text-decoration: none;
        }

        .form-footer a:hover {
            text-decoration: underline;
        }

        .icon-input {
            position: relative;
        }

        .icon-input svg {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            width: 20px;
            height: 20px;
            color: #94A3B8;
            pointer-events: none;
        }

        @media (max-width: 800px) {
            body { padding: 1rem; }
            .auth-wrapper { flex-direction: column; min-height: auto; }
            .auth-brand { padding: 2.5rem; display: none; } /* Hide on mobile to save space */
            .auth-form-panel { padding: 2.5rem; }
        }
    </style>
</head>

<body>

    <a href="/" class="back-home">
        <i data-lucide="arrow-left"></i> Back to home
    </a>

    <div class="auth-wrapper">
        <!-- Left brand panel -->
        <div class="auth-brand">
            <a href="/" class="brand-logo" style="display:flex; align-items:center; gap: 12px; text-decoration:none;">
                <img src="/images/teach.jpg" alt="Teachures Logo" style="height: 48px; border-radius: 8px; object-fit: contain;">
            </a>

            <div>
                <h2 class="brand-headline">Learn Without Limits.</h2>
                <p class="brand-sub">Join thousands of students mastering new skills with world-class instructors.</p>
            </div>

            <div class="brand-stats">
                <div>
                    <span class="brand-stat-num">12K+</span>
                    <span class="brand-stat-label">Learners</span>
                </div>
                <div>
                    <span class="brand-stat-num">400+</span>
                    <span class="brand-stat-label">Courses</span>
                </div>
                <div>
                    <span class="brand-stat-num">95%</span>
                    <span class="brand-stat-label">Completion</span>
                </div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-form-panel">
            <%- body %>
        </div>
    </div>

    <script>lucide.createIcons();</script>
</body>

</html>