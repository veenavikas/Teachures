<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (typeof title !== 'undefined' ? title + ' | Teachures' : 'Teachures | SaaS LMS') %>
  </title>
  <% if (typeof seoDesc !== 'undefined' && seoDesc) { %>
    <meta name="description" content="<%= seoDesc %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta name="twitter:description" content="<%= seoDesc %>">
  <% } else { %>
    <meta name="description" content="Teachures - The premier SaaS LMS platform.">
    <meta property="og:description" content="Teachures - The premier SaaS LMS platform.">
    <meta name="twitter:description" content="Teachures - The premier SaaS LMS platform.">
  <% } %>

  <!-- Open Graph & Twitter Card Data -->
  <meta property="og:title" content="<%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (typeof title !== 'undefined' ? title + ' | Teachures' : 'Teachures | SaaS LMS') %>">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://teachures.com/images/og-image.jpg">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (typeof title !== 'undefined' ? title + ' | Teachures' : 'Teachures | SaaS LMS') %>">

  <!-- Favicon -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🐝</text></svg>">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css?v=beeChat">
  <link rel="stylesheet" href="/css/utilities.css">

  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    :root {
        --yellow: #FFC107;
        --yellow-gradient: linear-gradient(135deg, #FFD54F, #FF8F00);
        --bg-white: #FFFFFF;
        --bg-offwhite: #F8FAFC;
        --text-main: #0F172A;
        --text-secondary: #475569;
        --border-light: #E2E8F0;
    }
    body {
        background-color: var(--bg-white);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body>

  <%- include('../partials/navbar') %>

    <main style="padding-top: 80px; min-height: 80vh;">
      <%- body %>
    </main>

    <%- include('../partials/footer') %>

      <script src="/js/main.js"></script>
      <script>
        lucide.createIcons();
      </script>

      <!-- Bee Chatbot Widget -->
      <div id="beeChatbot" class="bee-chat-widget">
          <!-- Chat Bubble (FAB) -->
        <button id="beeChatFab" class="bee-chat-fab">
            <span style="font-size: 32px; line-height: 1;">🐝</span>
        </button>

          <!-- Chat Window -->
          <div id="beeChatWindow" class="bee-chat-window" style="display: none;">
              <div class="bee-chat-header">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="width: 32px; height: 32px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px;">
                        🐝
                    </div>
                      <div>
                          <h4 style="margin: 0; font-size: 1rem; color: white;">Bee</h4>
                          <span style="font-size: 0.75rem; color: rgba(255,255,255,0.8);">AI Assistant</span>
                      </div>
                  </div>
                  <button id="beeChatCloseBtn" style="background: none; border: none; color: white; cursor: pointer; padding: 4px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
              </div>
              
              <div id="beeChatMessages" class="bee-chat-messages">
                  <!-- Messages will appear here -->
                  <div class="bee-message bee-message-bot">
                      <div class="bee-bubble">Hi there! I'm Bee 🐝. How can I help you today?</div>
                  </div>
              </div>

              <div class="bee-chat-input-area">
                  <input type="text" id="beeChatInput" placeholder="Ask me anything..." autocomplete="off">
                  <button id="beeChatSendBtn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
              </div>
          </div>
      </div>
      
      <script src="/js/chatbot.js"></script>

      <%- include('../partials/cookie-banner') %>
</body>

</html>