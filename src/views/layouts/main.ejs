<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (typeof title !== 'undefined' ? title + ' | Teachures' : 'Teachures | SaaS LMS') %>
  </title>
  <% if (typeof seoDesc !== 'undefined' && seoDesc) { %>
    <meta name="description" content="<%= seoDesc %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta name="twitter:description" content="<%= seoDesc %>">
  <% } else { %>
    <meta name="description" content="Teachures - The premier SaaS LMS platform.">
    <meta property="og:description" content="Teachures - The premier SaaS LMS platform.">
    <meta name="twitter:description" content="Teachures - The premier SaaS LMS platform.">
  <% } %>

  <!-- Open Graph & Twitter Card Data -->
  <meta property="og:title" content="<%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (typeof title !== 'undefined' ? title + ' | Teachures' : 'Teachures | SaaS LMS') %>">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://teachures.com/images/og-image.jpg">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (typeof title !== 'undefined' ? title + ' | Teachures' : 'Teachures | SaaS LMS') %>">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/base.css?v=lighttheme1">
  <link rel="stylesheet" href="/css/components.css?v=lighttheme1">

  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    :root {
        --yellow: #FFC107;
        --yellow-gradient: linear-gradient(135deg, #FFD54F, #FF8F00);
        --bg-white: #FFFFFF;
        --bg-offwhite: #F8FAFC;
        --text-main: #0F172A;
        --text-secondary: #475569;
        --border-light: #E2E8F0;
    }
    body {
        background-color: var(--bg-white);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body>

  <%- include('../partials/navbar') %>

    <main style="padding-top: 80px; min-height: 80vh;">
      <%- body %>
    </main>

    <%- include('../partials/footer') %>

      <script src="/js/main.js"></script>
      <script>
        lucide.createIcons();
      </script>

      <%- include('../partials/cookie-banner') %>
</body>

</html>