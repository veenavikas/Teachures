<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' | Dashboard' : 'Dashboard' %>
    </title>

    <meta property="og:title" content="<%= typeof title !=='undefined' ? title + ' | Dashboard' : 'Dashboard' %>">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://teachures.com/images/og-image.jpg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= typeof title !=='undefined' ? title + ' | Dashboard' : 'Dashboard' %>">

    <!-- Mobile App PWA Meta Tags -->
    <meta name="theme-color" content="#ffffff">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Teachures">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/base.css?v=lighttheme2">
    <link rel="stylesheet" href="/css/components.css?v=beeChat">

    <style>
        :root {
            --yellow: #FFC107;
            --yellow-gradient: linear-gradient(135deg, #FFD54F, #FF8F00);
            --bg-white: #FFFFFF;
            --bg-offwhite: #F8FAFC;
            --text-main: #0F172A;
            --text-secondary: #475569;
            --border-light: #E2E8F0;
        }

        body {
            display: flex;
            height: 100vh;
            overflow: hidden;
            background-color: var(--bg-white);
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
        }

        .sidebar {
            width: 260px;
            background-color: var(--bg-white);
            border-right: 1px solid var(--border-light);
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar-nav {
            flex: 1;
            padding: 1.5rem 0;
            overflow-y: auto;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 0.85rem 1.5rem;
            color: var(--text-secondary);
            text-decoration: none;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            gap: 12px;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .nav-item:hover {
            color: #D97706;
            background-color: var(--bg-offwhite);
        }

        .nav-item.active {
            color: #D97706;
            border-left-color: #D97706;
            background-color: rgba(217, 119, 6, 0.05);
            font-weight: 600;
        }

        .sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: var(--border-light);
            background-size: cover;
            background-position: center;
            border: 2px solid #D97706;
        }

        .user-info .name {
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--text-main);
        }

        .user-info .role {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background-color: var(--bg-offwhite);
        }

        .topbar {
            height: 70px;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            background-color: var(--bg-white);
        }

        .dashboard-body {
            flex: 1;
            padding: 2.5rem;
            overflow-y: auto;
        }

        .wordmark {
            font-family: 'Inter', sans-serif;
            font-size: 1.5rem;
            letter-spacing: -0.5px;
            font-weight: 800;
            color: var(--text-main);
        }

        .text-primary {
            color: #D97706 !important;
        }

        .logo-icon {
            width: 32px;
            height: 32px;
            background: var(--yellow-gradient);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .btn-outline {
            border: 1px solid var(--border-light);
            background: var(--bg-white);
            color: var(--text-secondary);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-outline:hover {
            background: var(--bg-offwhite);
            color: var(--text-main);
            border-color: #CBD5E1;
        }

        /* Mobile App Styles */
        .mobile-bottom-nav {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: var(--bg-white);
            border-top: 1px solid var(--border-light);
            z-index: 1000;
            justify-content: space-around;
            padding: 0.75rem 0;
            padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));
            box-shadow: 0 -4px 20px rgba(0,0,0,0.05);
        }
        
        .mobile-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.7rem;
            font-weight: 600;
            flex: 1;
            background: none;
            border: none;
            cursor: pointer;
        }
        
        .mobile-nav-item.active {
            color: #D97706;
        }
        .mobile-nav-item.active i {
            color: #D97706;
            stroke-width: 2.5px;
        }

        @media (max-width: 768px) {
            body {
                -webkit-tap-highlight-color: transparent;
            }
            .sidebar {
                position: fixed;
                left: 0;
                top: 0;
                height: 100%;
                transform: translateX(-100%);
                transition: transform 0.3s ease;
                box-shadow: 10px 0 25px rgba(0,0,0,0.1);
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .topbar {
                padding: 0 1rem;
            }
            .dashboard-body {
                padding: 1.5rem 1rem;
                padding-bottom: 85px; /* Space for bottom nav */
            }
            .mobile-bottom-nav {
                display: flex !important;
            }
            /* Hide the native hamburger menu if we are using bottom nav */
            #dashboardMenuToggle {
                display: none;
            }
        }
    </style>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/" style="display:flex; align-items:center; text-decoration:none;">
                <img src="/images/teach.jpg" alt="Teachures Logo" style="height: 40px; border-radius: 6px; object-fit: contain;">
            </a>
        </div>

        <nav class="sidebar-nav" aria-label="Sidebar Navigation">
            <!-- Injected Sidebar per role: Admin, Trainer, or Learner -->
            <%- include(sidebarPartial) %>
        </nav>

        <div class="sidebar-footer">
            <div class="avatar" style="background-image: url('<%= user?.avatar || '' %>');"></div>
            <div class="user-info">
                <div class="name">
                    <%= user?.name || 'User Name' %>
                </div>
                <div class="role">
                    <%= user?.role || 'Learner' %>
                </div>
            </div>
        </div>
    </aside>

    <main class="main-content" role="main">
        <header class="topbar" role="banner">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <button class="mobile-menu-btn btn-outline" id="dashboardMenuToggle" aria-label="Open Sidebar" style="padding: 0.5rem; border: none;">
                    <i data-lucide="menu"></i>
                </button>
                <h2 style="font-weight: 700; margin: 0; font-size: 1.25rem; color: var(--text-main);">
                    <%= title %>
                </h2>
            </div>
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="position: relative;">
                    <button class="btn-outline" id="notificationBtn" aria-label="Notifications"
                        style="padding: 0.5rem;">
                        <i data-lucide="bell" style="width: 20px; height: 20px;"></i>
                        <span id="notificationBadge"
                            style="display: none; position: absolute; top: -5px; right: -5px; background: #EF4444; color: white; font-size: 0.65rem; font-weight: bold; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">0</span>
                    </button>
                    <!-- Notification Dropdown -->
                    <div id="notificationDropdown"
                        style="display: none; position: absolute; top: 100%; right: 0; width: 320px; max-height: 400px; z-index: 100; margin-top: 10px; padding: 0; overflow: hidden; display: flex; flex-direction: column; opacity: 0; pointer-events: none; transition: opacity 0.2s; box-shadow: 0 10px 25px rgba(0,0,0,0.1); background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px;">
                        <div
                            style="padding: 1rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; background: var(--bg-offwhite);">
                            <h4 style="margin: 0; font-size: 0.95rem; font-weight: 700;">Notifications</h4>
                            <button id="markAllNotificationsBtn"
                                style="background: none; border: none; color: #D97706; font-size: 0.8rem; cursor: pointer; font-weight: 600;">Mark
                                all read</button>
                        </div>
                        <div id="notificationList" style="overflow-y: auto; flex: 1; max-height: 300px;">
                            <!-- Notifications injected here via JS -->
                            <div style="padding: 2rem; text-align: center; color: var(--text-secondary); font-size: 0.85rem;">
                                <i data-lucide="check-circle"
                                    style="width: 24px; height: 24px; margin-bottom: 0.5rem; opacity: 0.5; color: #10B981;"></i>
                                <br>You're all caught up!
                            </div>
                        </div>
                    </div>
                </div>
                <form action="/api/v1/auth/logout" method="POST" style="margin:0;">
                    <button class="btn-outline" type="submit" aria-label="Log Out"
                        style="padding: 0.5rem;"><i data-lucide="log-out" style="width: 20px; height: 20px;"></i></button>
                </form>
            </div>
        </header>

        <div class="dashboard-body">
            <%- body %>
        </div>
    </main>

    <!-- MOBILE BOTTOM NAVIGATION -->
    <nav class="mobile-bottom-nav">
        <% if (user?.role === 'STUDENT') { %>
            <a href="/student/dashboard" class="mobile-nav-item <%= path === '/student/dashboard' ? 'active' : '' %>">
                <i data-lucide="layout-dashboard" style="width:24px;height:24px;"></i>
                <span>Home</span>
            </a>
            <a href="/student/my-courses" class="mobile-nav-item <%= path.startsWith('/student/my-courses') ? 'active' : '' %>">
                <i data-lucide="play-circle" style="width:24px;height:24px;"></i>
                <span>Learn</span>
            </a>
            <a href="/student/gamification" class="mobile-nav-item <%= path === '/student/gamification' ? 'active' : '' %>">
                <i data-lucide="trophy" style="width:24px;height:24px;"></i>
                <span>Rank</span>
            </a>
            <a href="/student/profile" class="mobile-nav-item <%= path === '/student/profile' ? 'active' : '' %>">
                <i data-lucide="user" style="width:24px;height:24px;"></i>
                <span>Profile</span>
            </a>
        <% } else if (user?.role === 'INSTRUCTOR') { %>
            <a href="/instructor/dashboard" class="mobile-nav-item <%= path === '/instructor/dashboard' ? 'active' : '' %>">
                <i data-lucide="layout-dashboard" style="width:24px;height:24px;"></i>
                <span>Home</span>
            </a>
            <a href="/instructor/courses" class="mobile-nav-item <%= path.startsWith('/instructor/courses') ? 'active' : '' %>">
                <i data-lucide="book-open" style="width:24px;height:24px;"></i>
                <span>Courses</span>
            </a>
            <a href="/instructor/analytics" class="mobile-nav-item <%= path === '/instructor/analytics' ? 'active' : '' %>">
                <i data-lucide="bar-chart" style="width:24px;height:24px;"></i>
                <span>Data</span>
            </a>
            <a href="/instructor/profile" class="mobile-nav-item <%= path === '/instructor/profile' ? 'active' : '' %>">
                <i data-lucide="user" style="width:24px;height:24px;"></i>
                <span>Profile</span>
            </a>
        <% } else { %>
            <a href="/admin/dashboard" class="mobile-nav-item <%= path === '/admin/dashboard' ? 'active' : '' %>">
                <i data-lucide="layout-dashboard" style="width:24px;height:24px;"></i>
                <span>Home</span>
            </a>
            <a href="/admin/users" class="mobile-nav-item <%= path.startsWith('/admin/users') ? 'active' : '' %>">
                <i data-lucide="users" style="width:24px;height:24px;"></i>
                <span>Users</span>
            </a>
            <a href="/admin/courses" class="mobile-nav-item <%= path.startsWith('/admin/courses') ? 'active' : '' %>">
                <i data-lucide="book" style="width:24px;height:24px;"></i>
                <span>Courses</span>
            </a>
            <button class="mobile-nav-item" id="dashboardMenuToggleBottom" aria-label="More">
                <i data-lucide="menu" style="width:24px;height:24px;"></i>
                <span>More</span>
            </button>
        <% } %>
    </nav>

    <script src="/js/main.js"></script>
    <script>
        lucide.createIcons();

        // -----------------------------
        // Session Inactivity Timeout (15m)
        // -----------------------------
        let inactivityTime = function () {
            let time;
            const timeoutDuration = 15 * 60 * 1000; // 15 minutes
            
            function logout() {
                alert("Your session has expired due to inactivity. You will be logged out securely.");
                window.location.href = '/api/v1/auth/logout';
            }
            function resetTimer() {
                clearTimeout(time);
                time = setTimeout(logout, timeoutDuration);
            }

            window.onload = resetTimer;
            document.onmousemove = resetTimer;
            document.onkeypress = resetTimer;
            document.onclick = resetTimer;
            document.onscroll = resetTimer;
        };
        inactivityTime();

        // -----------------------------
        // Mobile Sidebar Toggle
        // -----------------------------
        const toggleBtn = document.getElementById('dashboardMenuToggle');
        const toggleBtnBottom = document.getElementById('dashboardMenuToggleBottom');
        const sidebar = document.querySelector('.sidebar');
        if (sidebar) {
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    sidebar.classList.toggle('open');
                });
            }
            if (toggleBtnBottom) {
                toggleBtnBottom.addEventListener('click', () => {
                    sidebar.classList.toggle('open');
                });
            }
            document.querySelector('.main-content').addEventListener('click', (e) => {
                if (window.innerWidth <= 768 && sidebar.classList.contains('open') && (!toggleBtn || !toggleBtn.contains(e.target)) && (!toggleBtnBottom || !toggleBtnBottom.contains(e.target))) {
                    sidebar.classList.remove('open');
                }
            });
        }

        // -----------------------------
        // Notification System
        // -----------------------------
        const notifDropdown = document.getElementById('notificationDropdown');
        const notifBadge = document.getElementById('notificationBadge');
        const notifList = document.getElementById('notificationList');
        let isNotifOpen = false;

        function toggleNotifications() {
            isNotifOpen = !isNotifOpen;
            if(isNotifOpen) {
                notifDropdown.style.display = 'flex';
                // slight delay for transition
                setTimeout(() => {
                    notifDropdown.style.opacity = '1';
                    notifDropdown.style.pointerEvents = 'auto';
                }, 10);
                fetchNotifications(); // Refresh on open
            } else {
                notifDropdown.style.opacity = '0';
                notifDropdown.style.pointerEvents = 'none';
                setTimeout(() => {
                    notifDropdown.style.display = 'none';
                }, 200);
            }
        }

        // Close when clicking outside
        document.addEventListener('click', (e) => {
            const btn = document.getElementById('notificationBtn');
            if(isNotifOpen && !notifDropdown.contains(e.target) && !btn.contains(e.target)) {
                toggleNotifications();
            }
        });

        async function fetchNotifications() {
            try {
                const res = await fetch('/api/v1/notifications');
                const data = await res.json();
                
                if(data.success) {
                    // Update Badge
                    if(data.unreadCount > 0) {
                        notifBadge.style.display = 'flex';
                        notifBadge.innerText = data.unreadCount > 9 ? '9+' : data.unreadCount;
                    } else {
                        notifBadge.style.display = 'none';
                    }

                    // Render List
                    if(data.data.length === 0) {
                        notifList.innerHTML = `<div style="padding: 2rem; text-align: center; color: var(--text-secondary); font-size: 0.85rem;"><i data-lucide="check-circle" style="width: 24px; height: 24px; margin-bottom: 0.5rem; opacity: 0.5; color: #10B981;"></i><br>You're all caught up!</div>`;
                    } else {
                        notifList.innerHTML = data.data.map(n => `
                            <div class="notification-item" data-id="${n.id}" data-link="${n.link || '#'}" style="padding: 1rem; border-bottom: 1px solid var(--border-light); cursor: pointer; background: ${n.isRead ? 'transparent' : 'var(--bg-offwhite)'}; transition: background 0.2s;">
                                <div style="font-size: 0.85rem; font-weight: ${n.isRead ? '500' : '700'}; color: var(--text-main); margin-bottom: 0.25rem;">${n.title}</div>
                                <div style="font-size: 0.75rem; color: var(--text-secondary); line-height: 1.4;">${n.message}</div>
                                <div style="font-size: 0.65rem; color: #94A3B8; margin-top: 0.5rem; font-weight: 500;">${new Date(n.createdAt).toLocaleDateString()}</div>
                            </div>
                        `).join('');
                    }
                    lucide.createIcons();
                }
            } catch(e) { console.error('Error fetching notifications'); }
        }

        async function markNotificationRead(id, link) {
            try {
                await fetch(`/api/v1/notifications/${id}/read`, { method: 'POST' });
                if(link !== '#') window.location.href = link;
                else fetchNotifications(); // Refresh inline if no link
            } catch(e) {}
        }

        async function markAllNotificationsRead() {
            try {
                await fetch('/api/v1/notifications/read-all', { method: 'POST' });
                fetchNotifications();
            } catch(e) {}
        }

        // Initial fetch on mount
        fetchNotifications();

        // Event listeners
        document.getElementById('notificationBtn').addEventListener('click', toggleNotifications);
        
        document.getElementById('markAllNotificationsBtn').addEventListener('click', markAllNotificationsRead);

        notifList.addEventListener('click', (e) => {
            const item = e.target.closest('.notification-item');
            if (item) {
                markNotificationRead(item.dataset.id, item.dataset.link);
            }
        });
        
        notifList.addEventListener('mouseover', (e) => {
            const item = e.target.closest('.notification-item');
            if (item) item.style.background = 'var(--bg-offwhite)';
        });
        
        notifList.addEventListener('mouseout', (e) => {
            const item = e.target.closest('.notification-item');
            if (item) {
                const isRead = !item.style.background.includes('offwhite'); 
                item.style.background = 'transparent'; 
            }
        });

    </script>

    <!-- Bee Chatbot Widget -->
    <div id="beeChatbot" class="bee-chat-widget">
        <!-- Chat Bubble (FAB) -->
        <button id="beeChatFab" class="bee-chat-fab">
            <span style="font-size: 32px; line-height: 1;">🐝</span>
        </button>

        <!-- Chat Window -->
        <div id="beeChatWindow" class="bee-chat-window" style="display: none;">
            <div class="bee-chat-header">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="width: 32px; height: 32px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px;">
                        🐝
                    </div>
                    <div>
                        <h4 style="margin: 0; font-size: 1rem; color: white;">Bee</h4>
                        <span style="font-size: 0.75rem; color: rgba(255,255,255,0.8);">AI Assistant</span>
                    </div>
                </div>
                <button id="beeChatCloseBtn" style="background: none; border: none; color: white; cursor: pointer; padding: 4px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            
            <div id="beeChatMessages" class="bee-chat-messages">
                <!-- Messages will appear here -->
                <div class="bee-message bee-message-bot">
                    <div class="bee-bubble">Hi there! I'm Bee 🐝. How can I help you today?</div>
                </div>
            </div>

            <div class="bee-chat-input-area">
                <input type="text" id="beeChatInput" placeholder="Ask me anything..." autocomplete="off">
                <button id="beeChatSendBtn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
            </div>
        </div>
    </div>
    
    <script src="/js/chatbot.js"></script>

    <%- include('../partials/cookie-banner') %>
</body>

</html>