<h2 class="form-title">Welcome back</h2>
<p class="form-subtitle">Log in to access your dashboard.</p>

<div id="error-message" style="display: none; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #EF4444; padding: 1rem; border-radius: 10px; margin-bottom: 1.5rem; font-size: 0.9rem;"></div>

<form action="/api/v1/auth/login" method="POST">
    <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" required placeholder="you@example.com">
    </div>

    <div class="form-group">
        <label class="form-label" style="display: flex; justify-content: space-between; align-items: center;">
            <span>Password</span>
            <a href="/forgot-password"
                style="font-size:0.8rem; color:#F5C518; text-transform:none; letter-spacing:0; font-weight:400;">Forgot
                password?</a>
        </label>
        <div class="icon-input">
            <input type="password" name="password" id="passwordField" class="form-control" required
                placeholder="••••••••">
            <i data-lucide="eye" id="togglePassword"
                style="cursor:pointer; pointer-events:all; color:#94A3B8;"></i>
        </div>
    </div>

    <button type="submit" class="btn-submit">Log In →</button>
</form>

<div class="divider">or continue with</div>

<a href="/api/v1/auth/google" class="btn-google" style="text-decoration: none;">
    <svg width="18" height="18" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
        <path fill="#EA4335"
            d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
        <path fill="#4285F4"
            d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
        <path fill="#FBBC05"
            d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
        <path fill="#34A853"
            d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
    </svg>
    Continue with Google
</a>

<p class="form-footer">Don't have an account? <a href="/register">Sign up free</a></p>

<script>
    const toggleBtn = document.getElementById('togglePassword');
    const passwordField = document.getElementById('passwordField');
    if (toggleBtn) {
        toggleBtn.addEventListener('click', function () {
            passwordField.type = passwordField.type === 'password' ? 'text' : 'password';
        });
    }

    const urlParams = new URLSearchParams(window.location.search);
    const error = urlParams.get('error');
    const errorDiv = document.getElementById('error-message');
    if (error === 'instructor_pending') {
        errorDiv.textContent = 'Your Instructor account is currently pending admin approval.';
        errorDiv.style.display = 'block';
    } else if (error === 'invalid_credentials') {
        errorDiv.textContent = 'Invalid email or password. Please try again.';
        errorDiv.style.display = 'block';
    }
</script>