<h2 class="form-title">Create Account</h2>
<p class="form-subtitle">Start learning or teaching today — it's free.</p>

<form action="/api/v1/auth/register" method="POST">
    <div class="form-group">
        <label class="form-label">Full Name</label>
        <input type="text" name="name" class="form-control" required placeholder="Jane Doe">
    </div>

    <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" required placeholder="you@example.com">
    </div>

    <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" required minlength="8"
            placeholder="At least 8 characters">
    </div>

    <div class="form-group">
        <label class="form-label">I want to</label>
        <div style="display: flex; gap: 0.75rem; margin-top: 0.5rem;">
            <label
                style="flex:1; padding: 1rem; border: 1px solid var(--border-light); border-radius: 12px; cursor: pointer; display: flex; align-items: center; gap: 12px; background: var(--bg-offwhite); transition: all 0.2s;"
                id="label-student">
                <input type="radio" name="role" value="STUDENT" checked style="accent-color: #D97706; display:none;"
                    id="role-student">
                <span style="font-size:1.5rem;">🎓</span>
                <span style="color:var(--text-main); font-weight:600; font-size:1rem;">Learn</span>
            </label>
            <label
                style="flex:1; padding: 1rem; border: 1px solid var(--border-light); border-radius: 12px; cursor: pointer; display: flex; align-items: center; gap: 12px; background: var(--bg-offwhite); transition: all 0.2s;"
                id="label-instructor">
                <input type="radio" name="role" value="INSTRUCTOR" style="accent-color: #D97706; display:none;"
                    id="role-instructor">
                <span style="font-size:1.5rem;">🧑‍🏫</span>
                <span style="color:var(--text-main); font-weight:600; font-size:1rem;">Teach</span>
            </label>
        </div>
    </div>

    <button type="submit" class="btn-submit">Create Account →</button>
</form>

<div class="divider">or continue with</div>

<a href="/api/v1/auth/google" class="btn-google" style="text-decoration: none;">
    <svg width="18" height="18" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
        <path fill="#EA4335"
            d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
        <path fill="#4285F4"
            d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
        <path fill="#FBBC05"
            d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
        <path fill="#34A853"
            d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
    </svg>
    Continue with Google
</a>

<p class="form-footer">Already have an account? <a href="/login">Log in</a></p>

<script>
    const labelStudent = document.getElementById('label-student');
    const labelInstructor = document.getElementById('label-instructor');
    const roleStudent = document.getElementById('role-student');
    const roleInstructor = document.getElementById('role-instructor');

    function updateSelection() {
        labelStudent.style.borderColor = roleStudent.checked ? '#D97706' : '#E2E8F0';
        labelStudent.style.background = roleStudent.checked ? 'rgba(217,119,6,0.05)' : '#F8FAFC';
        labelInstructor.style.borderColor = roleInstructor.checked ? '#D97706' : '#E2E8F0';
        labelInstructor.style.background = roleInstructor.checked ? 'rgba(217,119,6,0.05)' : '#F8FAFC';
    }

    labelStudent.addEventListener('click', () => { roleStudent.checked = true; updateSelection(); });
    labelInstructor.addEventListener('click', () => { roleInstructor.checked = true; updateSelection(); });
    updateSelection();
</script>