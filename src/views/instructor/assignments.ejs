<h2 style="font-family: var(--font-heading); margin-bottom: 2rem;">Assignment Submissions</h2>

<div class="card">
    <div style="overflow-x: auto;">
        <table class="table">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Lesson</th>
                    <th>Submitted At</th>
                    <th>Status</th>
                    <th>Grade</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (submissions && submissions.length > 0) { %>
                    <% submissions.forEach(sub => { %>
                        <tr>
                            <td>
                                <div><strong><%= sub.user.name %></strong></div>
                                <div style="font-size: 0.8rem; color: var(--color-gray-light);"><%= sub.user.email %></div>
                            </td>
                            <td><%= sub.assignment.lesson.title %></td>
                            <td><%= new Date(sub.submittedAt).toLocaleDateString() %></td>
                            <td>
                                <% if (sub.status === 'PENDING') { %>
                                    <span class="badge" style="background: var(--color-warning); color: black;">Pending</span>
                                <% } else if (sub.status === 'GRADED') { %>
                                    <span class="badge" style="background: var(--color-success); color: white;">Graded</span>
                                <% } else { %>
                                    <span class="badge" style="background: var(--color-danger); color: white;"><%= sub.status %></span>
                                <% } %>
                            </td>
                            <td><%= sub.grade !== null ? sub.grade + '%' : '-' %></td>
                            <td>
                                <button class="btn btn-outline btn-sm" onclick="openGradeModal('<%= sub.id %>', '<%= sub.status %>', '<%= sub.grade || '' %>', '<%= sub.feedback || '' %>')">
                                    <i data-lucide="check-square" style="width: 14px;"></i> Grade
                                </button>
                                <a href="<%= sub.fileUrl %>" target="_blank" class="btn btn-outline btn-sm" title="View Submission File">
                                    <i data-lucide="external-link" style="width: 14px;"></i>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 2rem; color: var(--color-gray-light);">
                            No submissions found.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Grading Modal -->
<div class="modal-overlay" id="gradeModal">
    <div class="modal">
        <div class="modal-header">
            <h3>Grade Submission</h3>
            <button class="close-modal" onclick="closeGradeModal()"><i data-lucide="x"></i></button>
        </div>
        <form id="gradeForm">
            <input type="hidden" id="subId">
            <div class="form-group">
                <label class="form-label">Status</label>
                <select id="subStatus" class="form-control">
                    <option value="PENDING">Pending</option>
                    <option value="GRADED">Graded</option>
                    <option value="REJECTED">Rejected</option>
                </select>
            </div>
            <div class="form-group" style="margin-top: 1rem;">
                <label class="form-label">Grade (%)</label>
                <input type="number" id="subGrade" class="form-control" min="0" max="100">
            </div>
            <div class="form-group" style="margin-top: 1rem;">
                <label class="form-label">Feedback</label>
                <textarea id="subFeedback" class="form-control" rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top: 1.5rem; width: 100%;">Save Grade</button>
        </form>
    </div>
</div>

<script>
    function openGradeModal(id, status, grade, feedback) {
        document.getElementById('subId').value = id;
        document.getElementById('subStatus').value = status;
        document.getElementById('subGrade').value = grade;
        document.getElementById('subFeedback').value = feedback;
        document.getElementById('gradeModal').style.display = 'flex';
    }

    function closeGradeModal() {
        document.getElementById('gradeModal').style.display = 'none';
    }

    document.getElementById('gradeForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('subId').value;
        const status = document.getElementById('subStatus').value;
        const grade = document.getElementById('subGrade').value;
        const feedback = document.getElementById('subFeedback').value;
        const btn = e.target.querySelector('button');

        btn.disabled = true;

        try {
            const res = await fetch(`/api/v1/courses/assignments/submissions/${id}/grade`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    status, 
                    grade: grade ? parseFloat(grade) : null, 
                    feedback 
                })
            });

            if(res.ok) {
                window.location.reload();
            } else {
                alert('Failed to save grade.');
                btn.disabled = false;
            }
        } catch (error) {
            alert('Error saving grade.');
            btn.disabled = false;
        }
    });
</script>
