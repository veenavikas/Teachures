<h2 style="font-family: var(--font-heading); margin-bottom: 2rem;">Q&A Forums</h2>

<div class="card" style="padding: 2rem;">
    <% if (qnas && qnas.length) { %>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <% qnas.forEach(q => { %>
                <div style="border: 1px solid var(--color-gray-mid); border-radius: 8px; padding: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <div>
                            <span class="badge" style="background: var(--color-gray-mid); color: var(--color-white); margin-bottom: 0.5rem; display: inline-block;">
                                <%= q.course.title %>
                            </span>
                            <h3 style="margin-bottom: 0.25rem;"><%= q.user.name %> asked:</h3>
                            <p style="color: var(--color-gray-light);"><%= q.question %></p>
                            <% if (q.details) { %>
                                <p style="color: var(--color-gray-light); font-size: 0.9rem; margin-top: 0.5rem;"><%= q.details %></p>
                            <% } %>
                        </div>
                        <span style="font-size: 0.85rem; color: var(--color-gray-light);">
                            <%= new Date(q.createdAt).toLocaleDateString() %>
                        </span>
                    </div>

                    <!-- Replies -->
                    <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.1);">
                        <% if (q.replies && q.replies.length > 0) { %>
                            <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.5rem;">
                                <% q.replies.forEach(reply => { %>
                                    <div style="display: flex; gap: 1rem; background: <%= reply.user.role === 'INSTRUCTOR' ? 'rgba(59, 130, 246, 0.1)' : 'rgba(255,255,255,0.05)' %>; padding: 1rem; border-radius: 4px;">
                                        <div style="flex: 1;">
                                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                                                <strong style="color: <%= reply.user.role === 'INSTRUCTOR' ? 'var(--color-primary)' : 'var(--color-white)' %>">
                                                    <%= reply.user.name %> <%= reply.user.role === 'INSTRUCTOR' ? '(Instructor)' : '' %>
                                                </strong>
                                                <span style="font-size: 0.8rem; color: var(--color-gray-light);">
                                                    <%= new Date(reply.createdAt).toLocaleDateString() %>
                                                </span>
                                            </div>
                                            <p style="color: var(--color-gray-light); margin: 0;"><%= reply.answer %></p>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p style="color: var(--color-warning); font-size: 0.9rem; margin-bottom: 1rem;">No replies yet.</p>
                        <% } %>

                        <!-- Reply Form -->
                        <form class="reply-form" style="display: flex; gap: 1rem;">
                            <input type="hidden" name="qnaId" value="<%= q.id %>">
                            <input type="text" name="answer" class="form-control" placeholder="Write your reply..." required style="flex: 1;">
                            <button type="submit" class="btn btn-primary" style="white-space: nowrap;">Post Reply</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div style="text-align: center; padding: 3rem 0; color: var(--color-gray-light);">
            <i data-lucide="message-square" style="width: 48px; height: 48px; margin-bottom: 1rem; opacity: 0.5;"></i>
            <h3>No Questions Yet</h3>
            <p>Students haven't asked any questions in your courses.</p>
        </div>
    <% } %>
</div>

<script>
document.querySelectorAll('.reply-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button');
        const input = form.querySelector('input[name="answer"]');
        const qnaId = form.querySelector('input[name="qnaId"]').value;
        const answer = input.value;
        
        btn.disabled = true;

        try {
            const res = await fetch('/api/v1/courses/qna/reply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ qnaId, answer })
            });

            if(res.ok) {
                window.location.reload();
            } else {
                alert('Failed to post reply.');
                btn.disabled = false;
            }
        } catch (error) {
            alert('Error posting reply.');
            btn.disabled = false;
        }
    });
});
</script>
