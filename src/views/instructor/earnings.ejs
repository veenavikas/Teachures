<div class="grid-3" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Total Earnings -->
    <div class="card" style="padding: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
            <div>
                <p class="text-muted" style="margin-bottom: 0.5rem; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px;">Total Earnings</p>
                <h2 style="font-size: 2rem; margin: 0; color: var(--color-success);">$<%= earnings.totalEarnings.toFixed(2) %></h2>
            </div>
            <div style="background: rgba(var(--color-success-rgb), 0.1); padding: 0.75rem; border-radius: 8px; color: var(--color-success);">
                <i data-lucide="dollar-sign" style="width: 24px; height: 24px;"></i>
            </div>
        </div>
        <p class="text-muted" style="font-size: 0.85rem; margin: 0;">Lifetime revenue (90% cut)</p>
    </div>
</div>

<div class="card" style="padding: 2rem;">
    <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem;">Recent Transactions</h3>

    <% if (earnings.recentTransactions.length === 0) { %>
        <p class="text-muted">No transactions found yet. Keep marketing your courses!</p>
    <% } else { %>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--color-gray-mid);">
                        <th style="padding: 1rem;">Date</th>
                        <th style="padding: 1rem;">Course</th>
                        <th style="padding: 1rem;">Your Earnings</th>
                    </tr>
                </thead>
                <tbody>
                    <% earnings.recentTransactions.forEach(tx => { %>
                        <tr style="border-bottom: 1px solid var(--color-gray-mid);">
                            <td style="padding: 1rem; color: var(--color-gray-light);"><%= tx.date %></td>
                            <td style="padding: 1rem; font-weight: 600;"><%= tx.course %></td>
                            <td style="padding: 1rem; color: var(--color-success);">+$<%= tx.amount.toFixed(2) %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
