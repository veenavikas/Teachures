<div class="kpi-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 2.5rem;">
    <div class="card" style="padding: 1.5rem; background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin:0;">Total Students</h3>
            <div style="padding: 0.5rem; background: rgba(217, 119, 6, 0.1); border-radius: 8px;"><i
                    data-lucide="users" style="color: #D97706; width: 20px; height: 20px;"></i></div>
        </div>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main); font-family: 'Inter', sans-serif;">
            <%= stats.totalStudents || 0 %>
        </div>
        <div style="color: #10B981; font-size: 0.85rem; margin-top: 0.75rem; font-weight: 600;"><i
                data-lucide="trending-up" style="width: 16px; height: 16px; vertical-align: text-bottom;"></i> +12% this month</div>
    </div>

    <div class="card" style="padding: 1.5rem; background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin:0;">Monthly Earnings</h3>
            <div style="padding: 0.5rem; background: rgba(217, 119, 6, 0.1); border-radius: 8px;"><i
                    data-lucide="dollar-sign" style="color: #D97706; width: 20px; height: 20px;"></i></div>
        </div>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main); font-family: 'Inter', sans-serif;">
            $<%= stats.monthlyEarnings || 0 %>
        </div>
        <div style="color: #10B981; font-size: 0.85rem; margin-top: 0.75rem; font-weight: 600;"><i
                data-lucide="trending-up" style="width: 16px; height: 16px; vertical-align: text-bottom;"></i> +5% this month</div>
    </div>

    <div class="card" style="padding: 1.5rem; background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin:0;">Active Courses</h3>
            <div style="padding: 0.5rem; background: rgba(217, 119, 6, 0.1); border-radius: 8px;"><i
                    data-lucide="book-open" style="color: #D97706; width: 20px; height: 20px;"></i></div>
        </div>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main); font-family: 'Inter', sans-serif;">
            <%= stats.activeCourses || 0 %>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.85rem; margin-top: 0.75rem; font-weight: 500;">
            2 drafts pending
        </div>
    </div>

    <div class="card" style="padding: 1.5rem; background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin:0;">Avg. Rating</h3>
            <div style="padding: 0.5rem; background: rgba(217, 119, 6, 0.1); border-radius: 8px;"><i data-lucide="star"
                    style="color: #D97706; width: 20px; height: 20px;"></i></div>
        </div>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main); font-family: 'Inter', sans-serif;">
            <%= stats.avgRating ? stats.avgRating.toFixed(1) : 'N/A' %>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.85rem; margin-top: 0.75rem; font-weight: 500;">Based on <%= stats.totalReviews || 0 %> reviews</div>
    </div>
</div>

<div class="grid-2" style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
    <!-- Chart Area -->
    <div class="card" style="padding: 1.5rem; background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
        <h3
            style="font-size: 1.1rem; font-weight: 700; color: var(--text-main); margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); padding-bottom: 1rem;">
            Enrollments & Views</h3>
        <div style="height: 300px; width: 100%; display: flex; align-items: center; justify-content: center;">
            <canvas id="enrollmentsChart"></canvas>
            <script id="chartData" type="application/json"><%- stats.chartData || '[0,0,0,0]' %></script>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
        <h3
            style="font-size: 1.1rem; font-weight: 700; color: var(--text-main); margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); padding-bottom: 1rem;">
            Recent Activity</h3>
        <div style="flex: 1; overflow-y: auto;">
            <% if(recentActivity && recentActivity.length) { %>
                <ul style="list-style: none; padding: 0;">
                    <% recentActivity.forEach(activity=> { %>
                        <li style="margin-bottom: 1.25rem; display: flex; gap: 1rem;">
                            <div
                                style="width: 10px; height: 10px; border-radius: 50%; background-color: #D97706; margin-top: 5px;">
                            </div>
                            <div>
                                <p style="margin: 0; font-size: 0.95rem; font-weight: 600; color: var(--text-main);">
                                    <%= activity.text %>
                                </p>
                                <small style="color: var(--text-secondary); font-weight: 500;">
                                    <%= activity.time %>
                                </small>
                            </div>
                        </li>
                        <% }) %>
                </ul>
                <% } else { %>
                    <p style="text-align: center; color: var(--text-secondary); margin-top: 2rem;">No recent activity.</p>
                    <% } %>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const chartData = JSON.parse(document.getElementById('chartData').textContent);
    if(document.getElementById('enrollmentsChart')) {
        new Chart(document.getElementById('enrollmentsChart'), {
            type: 'line',
            data: {
                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                datasets: [{
                    label: 'Enrollments',
                    data: chartData,
                    borderColor: '#D97706',
                    backgroundColor: 'rgba(217, 119, 6, 0.1)',
                    tension: 0.4,
                    fill: true,
                    borderWidth: 3,
                    pointBackgroundColor: '#FFFFFF',
                    pointBorderColor: '#D97706',
                    pointBorderWidth: 2,
                    pointRadius: 4
                }]
            },
            options: { 
                responsive: true, 
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { color: '#94A3B8', font: { family: 'Inter' } } },
                    y: { grid: { color: '#E2E8F0' }, ticks: { color: '#94A3B8', font: { family: 'Inter' } } }
                }
            }
        });
    }
});
</script>

<!-- Instructor Student Leaderboard Table -->
<div class="card" style="margin-top: 1.5rem; padding: 1.5rem; background: var(--bg-white); border: 1px solid var(--border-light); border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-light); padding-bottom: 1rem; margin-bottom: 1rem;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--text-main); margin: 0;">My Students Leaderboard</h3>
    </div>

    <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead>
            <tr style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">
                <th style="padding: 1rem 0; border-bottom: 2px solid var(--border-light);">Rank</th>
                <th style="padding: 1rem 0; border-bottom: 2px solid var(--border-light);">Learner Name</th>
                <th style="padding: 1rem 0; border-bottom: 2px solid var(--border-light);">Total Points</th>
            </tr>
        </thead>
        <tbody>
            <% if (instructorLeaderboard && instructorLeaderboard.length > 0) { %>
                <% instructorLeaderboard.forEach((user, idx) => { %>
                    <tr style="border-bottom: 1px solid var(--border-light);">
                        <td style="padding: 1rem 0; font-weight: 800; font-size: 1.1rem; color: #D97706;">
                            #<%= idx + 1 %>
                        </td>
                        <td style="padding: 1rem 0; font-weight: 600; color: var(--text-main);">
                            <%= user.name %>
                        </td>
                        <td style="padding: 1rem 0;">
                            <span style="background: rgba(217, 119, 6, 0.1); color: #D97706; border-radius: 6px; padding: 6px 12px; font-weight: 700; font-size: 0.9rem;">
                                <%= user.totalPoints %> XP
                            </span>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="3" style="padding: 3rem 0; text-align: center; color: var(--text-secondary);">No learners enrolled yet.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>