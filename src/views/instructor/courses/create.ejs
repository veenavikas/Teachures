<div style="max-width: 600px; margin: 0 auto; padding: 2rem 0;">
    <a href="/instructor/courses" class="text-muted"
        style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 2rem; font-size: 0.9rem;">
        <i data-lucide="arrow-left" class="icon-sm"></i> Back to Courses
    </a>

    <h2 class="auth-title">Create a New Course</h2>
    <p class="text-muted" style="margin-bottom: 2rem;">Fill in the basic details to get started. You can change these
        later.</p>

    <form id="createCourseForm" class="card" style="padding: 2.5rem; border-radius: 16px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid rgba(0,0,0,0.05);">
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label class="form-label" style="font-weight: 600; color: var(--color-gray-dark);">Course Title</label>
            <input type="text" id="title" class="form-control" required
                placeholder="e.g. Advanced Full-Stack with Node.js" style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid); transition: all 0.2s;">
            <small class="text-muted" style="display:block; margin-top:0.4rem;">Keep it clear and descriptive.</small>
        </div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label class="form-label" style="font-weight: 600; color: var(--color-gray-dark);">Course Description</label>
            <textarea id="description" class="form-control" required rows="4"
                placeholder="Briefly describe what students will learn..." style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid); transition: all 0.2s; resize: vertical;"></textarea>
            <small class="text-muted" style="display:block; margin-top:0.4rem;">This is required. You can expand on it later.</small>
        </div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label class="form-label" style="font-weight: 600; color: var(--color-gray-dark);">Category</label>
            <select id="category" class="form-control" required style="appearance: none; background-color: white; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid);">
                <option value="" disabled selected>Select a category</option>
                <option value="Development">Development</option>
                <option value="Business">Business</option>
                <option value="Design">Design</option>
                <option value="Marketing">Marketing</option>
            </select>
        </div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label class="form-label" style="font-weight: 600; color: var(--color-gray-dark);">Price ($ USD)</label>
            <input type="number" id="price" class="form-control" min="0" step="1" value="0" style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid);">
            <small class="text-muted" style="display:block; margin-top:0.4rem;">Set to 0 for a free course.</small>
        </div>

        <hr style="border: 0; border-top: 1px solid rgba(0,0,0,0.1); margin: 2.5rem 0;">

        <div style="display: flex; justify-content: flex-end; gap: 1rem;">
            <a href="/instructor/courses" class="btn btn-outline" style="border: none; border-radius: 8px; padding: 0.75rem 1.5rem;">Cancel</a>
            <button type="submit" class="btn btn-primary" style="border-radius: 8px; padding: 0.75rem 2rem; font-weight: 600; box-shadow: 0 4px 12px rgba(var(--color-primary-rgb), 0.3); transition: all 0.2s; background: linear-gradient(135deg, var(--color-primary), #4F46E5);">Create & Proceed</button>
        </div>
    </form>
</div>

<script>
    document.getElementById('createCourseForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const title = document.getElementById('title').value;
        const description = document.getElementById('description').value;
        const category = document.getElementById('category').value;
        const price = document.getElementById('price').value;

        // Disable button while loading
        const btn = e.target.querySelector('button[type="submit"]');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Creating...';
        btn.disabled = true;

        try {
            // Basic jwt fetch logic assuming token is stored in localStorage or handled via cookies in prod
            const res = await fetch('/api/v1/courses', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, description, category, price, isFree: price == 0 })
            });

            const data = await res.json();
            if (data.success) {
                window.location.href = `/instructor/courses/${data.data.id}/edit`;
            } else {
                alert(data.message || 'Error creating course');
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        } catch (err) {
            alert('Internal error communicating with API.');
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    });
</script>