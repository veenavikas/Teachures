<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h2 class="auth-title" style="margin: 0;">My Courses</h2>
    <a href="/instructor/courses/create" class="btn btn-primary"><i data-lucide="plus" style="margin-right: 8px;"></i>
        Create Course</a>
</div>

<div class="grid-3" style="margin-bottom: 2rem;">
    <% if (courses && courses.length> 0) { %>
        <% courses.forEach(course=> { %>
            <div class="card" style="position: relative;">
                <div
                    style="height: 180px; background-image: url('<%= course.thumbnailUrl || '/images/default-course.jpg' %>'); background-size: cover; background-position: center; position: relative;">
                    <% if (course.isPublished) { %>
                        <span
                            style="position: absolute; top: 10px; right: 10px; background: var(--color-success); color: var(--color-white); padding: 4px 8px; font-size: 0.75rem; font-weight: 700; border-radius: 4px; text-transform: uppercase;">Published</span>
                        <% } else { %>
                            <span
                                style="position: absolute; top: 10px; right: 10px; background: var(--color-gray-dark); color: var(--color-gray-light); padding: 4px 8px; font-size: 0.75rem; font-weight: 700; border-radius: 4px; text-transform: uppercase;">Draft</span>
                            <% } %>
                </div>
                <div style="padding: 1.5rem;">
                    <p class="text-primary"
                        style="font-size: 0.85rem; font-weight: 700; margin-bottom: 0.5rem; text-transform: uppercase;">
                        <%= course.category %>
                    </p>
                    <h3
                        style="font-size: 1.25rem; margin-bottom: 0.5rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <%= course.title %>
                    </h3>

                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; border-top: 1px solid var(--color-gray-mid); padding-top: 1rem;">
                        <div style="font-family: var(--font-mono); font-weight: 700;">$<%= course.price %>
                        </div>
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="/instructor/courses/<%= course.id %>/edit" class="btn btn-outline"
                                style="padding: 0.5rem; border: none; color: var(--color-gray-light);"><i
                                    data-lucide="edit-2" class="icon-sm"></i></a>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
                <% } else { %>
                    <div
                        style="grid-column: 1 / -1; text-align: center; padding: 4rem 2rem; border: 1px dashed var(--color-gray-mid); border-radius: 4px;">
                        <i data-lucide="book-open"
                            style="width: 48px; height: 48px; color: var(--color-gray-mid); margin-bottom: 1rem;"></i>
                        <h3 style="margin-bottom: 0.5rem;">No courses yet</h3>
                        <p class="text-muted" style="margin-bottom: 1.5rem;">Start building your first curriculum today.
                        </p>
                        <a href="/instructor/courses/create" class="btn btn-primary">Create Course</a>
                    </div>
                    <% } %>
</div>