<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= course.title %> - Teachures</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css?v=lighttheme1">
    <link rel="stylesheet" href="/css/components.css?v=lighttheme1">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --yellow: #FFC107;
            --yellow-dim: #FFB300;
            --yellow-gradient: linear-gradient(135deg, #FFD54F, #FF8F00);
            --bg-white: #FFFFFF;
            --bg-offwhite: #F8FAFC;
            --text-main: #0F172A;
            --text-secondary: #475569;
            --border-light: #E2E8F0;
            --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 10px 25px -3px rgba(0, 0, 0, 0.05);
            --radius-md: 16px;
        }

        body {
            background-color: var(--bg-white);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
        }

        .course-hero {
            background: var(--bg-offwhite);
            padding: 6rem 2rem 4rem;
            border-bottom: 1px solid var(--border-light);
            text-align: center;
        }

        .course-title {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 800;
            letter-spacing: -1px;
            color: var(--text-main);
            margin-bottom: 1rem;
        }

        .course-desc {
            font-size: 1.15rem;
            color: var(--text-secondary);
            max-width: 700px;
            margin: 0 auto 2rem;
        }

        .course-price {
            font-size: 2rem;
            font-weight: 800;
            color: #D97706;
            margin-bottom: 1.5rem;
        }

        .btn-enroll {
            display: inline-block;
            padding: 1rem 2.5rem;
            background: var(--yellow-gradient);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1rem;
            box-shadow: 0 4px 10px rgba(255,193,7,0.3);
            transition: all 0.3s;
        }

        .btn-enroll:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(255,193,7,0.4);
        }

        .prereq-alert {
            max-width: 600px;
            margin: 1.5rem auto 0;
            padding: 1.5rem;
            background: #FEF2F2;
            border: 1px solid #FECACA;
            border-radius: var(--radius-md);
            text-align: left;
        }

        .content-section {
            padding: 4rem 2rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 1.5rem;
        }

        .announcement-card, .review-card {
            background: var(--bg-white);
            padding: 1.5rem;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-light);
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow-sm);
        }

        .review-stars { color: #D97706; display: flex; gap: 0.25rem; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="course-hero">
        <h1 class="course-title"><%= course.title %></h1>
        <p class="course-desc"><%= course.description %></p>
        <div class="course-price">$<%= course.price %></div>
        
        <% if (prereqsMet) { %>
            <a href="/courses/<%= course.slug %>/checkout" class="btn-enroll">Enroll Now</a>
        <% } else { %>
            <div class="prereq-alert">
                <p style="color: #DC2626; font-weight: 700; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <i data-lucide="lock" style="width: 20px; height: 20px;"></i> Prerequisites Not Met
                </p>
                <p style="color: #7F1D1D; font-size: 0.95rem;">You must complete the following courses before enrolling:</p>
                <ul style="margin-top: 0.75rem; padding-left: 1.5rem; color: #991B1B;">
                    <% pendingPrereqs.forEach(p => { %>
                        <li><a href="/courses/<%= p.slug %>" style="color: #DC2626; font-weight: 600; text-decoration: none;"><%= p.title %></a></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>
    </div>

    <main class="content-section">
        <% if (announcements && announcements.length > 0) { %>
            <h2 class="section-title">Announcements</h2>
            <div style="margin-bottom: 4rem;">
                <% announcements.forEach(ann => { %>
                    <div class="announcement-card">
                        <h3 style="color: var(--text-main); margin-bottom: 0.5rem;"><%= ann.title %></h3>
                        <p style="color: var(--text-secondary); margin-bottom: 1rem; white-space: pre-wrap;"><%= ann.content %></p>
                        <small style="color: #94A3B8; font-weight: 500;"><%= new Date(ann.createdAt).toLocaleDateString() %></small>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <h2 class="section-title">Student Reviews</h2>
        <div>
            <% if (course.ratings && course.ratings.length > 0) { %>
                <% course.ratings.forEach(r => { %>
                    <div class="review-card">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                            <strong style="color: var(--text-main);"><%= r.user.name %></strong>
                            <div class="review-stars">
                                <% for(let i=0; i<5; i++) { %>
                                    <i data-lucide="star" style="width: 16px; height: 16px; <%= i < r.rating ? 'fill: currentColor;' : 'color: #CBD5E1;' %>"></i>
                                <% } %>
                            </div>
                        </div>
                        <p style="color: var(--text-secondary);"><%= r.review %></p>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="color: var(--text-secondary); text-align: center; padding: 3rem; background: var(--bg-offwhite); border-radius: var(--radius-md);">No reviews yet.</p>
            <% } %>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script>lucide.createIcons();</script>
</body>
</html>
