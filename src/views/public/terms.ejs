        .content-section h2 {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-main);
            margin: 3rem 0 1rem;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 0.5rem;
        }

        .content-section p, .content-section li {
            color: var(--text-secondary);
            line-height: 1.8;
            font-size: 1.1rem;
            margin-bottom: 1.2rem;
        }

        .content-section ul {
            margin-left: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .last-updated {
