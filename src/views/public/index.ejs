<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teachures — Build the career you've always imagined</title>
    <meta name="description" content="World-class learning platform for creators and learners. Enroll in 400+ courses, earn verified certificates, and build your future.">

    <!-- Mobile App PWA Meta Tags -->
    <meta name="theme-color" content="#ffffff">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Teachures">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            /* Premium Light Mode Variables */
            --yellow: #FFC107;
            --yellow-dim: #FFB300;
            --yellow-light: #FFF8E1;
            --yellow-gradient: linear-gradient(135deg, #FFD54F, #FF8F00);
            
            --bg-white: #FFFFFF;
            --bg-offwhite: #F8FAFC;
            --bg-muted: #F1F5F9;
            
            --text-main: #0F172A;
            --text-secondary: #475569;
            --text-muted: #94A3B8;
            
            --border-light: #E2E8F0;
            
            --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-md: 0 10px 25px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.03);
            --shadow-lg: 0 20px 40px -5px rgba(255, 193, 7, 0.15), 0 10px 20px -5px rgba(0, 0, 0, 0.04);
            
            --radius-md: 16px;
            --radius-lg: 24px;
            
            --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-white);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
            overflow-x: hidden;
            /* Premium subtle background glow */
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(255, 193, 7, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(255, 193, 7, 0.03) 0%, transparent 40%);
        }

        /* Typography */
        h1, h2, h3, h4, h5, h6 {
            line-height: 1.15;
            letter-spacing: -0.02em;
            color: var(--text-main);
        }

        .h1 { font-size: clamp(2rem, 10vw, 4.5rem); font-weight: 800; line-height: 1.1; }
        .h2 { font-size: clamp(1.8rem, 8vw, 3.5rem); font-weight: 700; line-height: 1.2; }
        
        .text-gradient {
            background: var(--yellow-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            color: transparent;
        }
        
        .font-serif { font-family: 'Playfair Display', serif; font-style: italic; }
        .text-center { text-align: center; }

        /* Premium Cards */
        .premium-card {
            background: var(--bg-white);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
        }

        .premium-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-lg);
            border-color: rgba(255, 193, 7, 0.3);
        }

        /* Scroll Reveal Animation Classes */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            will-change: opacity, transform;
        }
        
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
        
        .delay-100 { transition-delay: 100ms; }
        .delay-200 { transition-delay: 200ms; }
        .delay-300 { transition-delay: 300ms; }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            padding: 1.25rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: var(--transition-smooth);
        }

        nav.scrolled {
            padding: 1rem 5%;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            text-decoration: none;
        }

        .nav-logo img {
            height: 38px;
            object-fit: contain;
            border-radius: 4px;
        }

        .nav-links { display: flex; gap: 2.5rem; }
        .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
            transition: var(--transition-smooth);
        }
        .nav-links a:hover { color: var(--text-main); }

        .nav-actions { display: flex; gap: 1.5rem; align-items: center; }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.85rem 2rem;
            border-radius: 50px;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition-smooth);
            cursor: pointer;
            border: none;
            position: relative;
            overflow: hidden;
        }

        .btn-text { color: var(--text-main); background: transparent; padding: 0.85rem 1rem; }
        .btn-text:hover { color: var(--yellow-dim); }

        .btn-primary {
            background: var(--yellow-gradient);
            color: #0F172A;
            box-shadow: 0 4px 15px rgba(255, 193, 7, 0.3);
            font-weight: 700;
        }

        .btn-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 8px 25px rgba(255, 193, 7, 0.4);
        }

        .btn-primary::after {
            content: '';
            position: absolute;
            top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.6s ease;
        }
        .btn-primary:hover::after { left: 100%; }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--border-light);
            color: var(--text-main);
        }

        .btn-outline:hover {
            border-color: var(--yellow);
            color: var(--yellow-dim);
            background: rgba(255, 193, 7, 0.05);
        }

        /* Layout Helpers */
        .container { max-width: 1200px; margin: 0 auto; padding: 0 5%; }
        .section { padding: 8rem 0; position: relative; }
        .section-offwhite { background-color: var(--bg-offwhite); }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
            padding-top: 6rem;
            position: relative;
        }

        .hero-content { position: relative; z-index: 10; }
        .hero-content h1 { margin-bottom: 1.5rem; }
        
        .hero-subtitle {
            font-size: 1.15rem;
            color: var(--text-secondary);
            margin-bottom: 2.5rem;
            max-width: 480px;
        }

        .hero-actions { display: flex; gap: 1rem; align-items: center; }

        .hero-stats {
            margin-top: 3.5rem;
            display: flex;
            gap: 2.5rem;
            font-size: 0.9rem;
            color: var(--text-secondary);
            font-weight: 500;
            flex-wrap: wrap; /* allow wrapping on small screens */
        }
        .hero-stats strong {
            color: var(--text-main);
            display: block;
            font-size: 1.75rem;
            font-weight: 800;
            margin-bottom: 0.25rem;
        }

        /* Hero Visual Card */
        .hero-visual { position: relative; }
        
        .hero-card {
            max-width: 380px;
            margin-left: auto;
            position: relative;
            z-index: 2;
            padding: 2rem;
            border-radius: var(--radius-lg);
            background: white;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border-light);
            transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        .hero-card:hover {
            transform: perspective(1000px) rotateY(-5deg) rotateX(2deg) translateY(-10px);
        }
        
        .hero-card-img {
            width: 100%; height: 200px;
            background: var(--bg-muted);
            border-radius: var(--radius-md);
            margin-bottom: 1.5rem;
            display: flex; align-items: center; justify-content: center;
            background-image: radial-gradient(circle at center, white 0%, var(--bg-muted) 100%);
        }
        
        .hero-card-img i { color: var(--yellow-dim); width: 64px; height: 64px; filter: drop-shadow(0 10px 15px rgba(255,193,7,0.3)); }
        
        .hero-card-badges { display: flex; gap: 0.75rem; margin-bottom: 1rem; }
        
        .badge {
            font-size: 0.75rem; font-weight: 700; padding: 0.35rem 0.75rem;
            border-radius: 50px; text-transform: uppercase; letter-spacing: 0.5px;
        }
        
        .badge-yellow { background: var(--yellow-light); color: #D97706; }
        .badge-gray { background: var(--bg-muted); color: var(--text-secondary); }
        
        .hero-card-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text-main); }
        
        .hero-card-meta {
            display: flex; justify-content: space-between; align-items: center;
            font-size: 0.9rem; color: var(--text-secondary); font-weight: 500;
        }

        .hero-floating-badge {
            position: absolute; bottom: -20px; left: -10px;
            padding: 1rem 1.25rem;
            background: white;
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border-light);
            display: flex; align-items: center; gap: 1rem;
            z-index: 3;
            animation: float 6s ease-in-out infinite;
            max-width: 90%;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        .hero-floating-badge-icon {
            width: 48px; height: 48px;
            background: var(--yellow-light);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #D97706;
        }

        /* Domains Grid */
        .domains-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem; margin-top: 4rem;
        }
        
        .domain-card {
            padding: 2rem;
            text-decoration: none;
            color: var(--text-main);
            display: flex; flex-direction: column; gap: 1.5rem;
        }
        
        .domain-icon {
            width: 64px; height: 64px;
            background: var(--yellow-light);
            border-radius: var(--radius-md);
            display: flex; align-items: center; justify-content: center;
            color: #D97706;
            transition: var(--transition-smooth);
        }

        .domain-card:hover .domain-icon {
            transform: scale(1.1) rotate(5deg);
            background: var(--yellow-gradient);
            color: white;
            box-shadow: 0 10px 20px rgba(255,193,7,0.3);
        }
        
        .domain-title { font-weight: 700; font-size: 1.2rem; }
        .domain-count { font-size: 0.95rem; color: var(--text-secondary); font-weight: 500; }

        /* Enterprise Section */
        .enterprise-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
        .enterprise-features { display: flex; flex-direction: column; gap: 2.5rem; margin-top: 3rem; }
        
        .enterprise-feature h4 {
            font-size: 1.2rem; font-weight: 700; margin-bottom: 0.75rem;
            display: flex; align-items: center; gap: 1rem;
        }
        
        .enterprise-feature-icon {
            width: 32px; height: 32px; background: var(--yellow-light); color: #D97706;
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
        }
        
        .enterprise-feature p { color: var(--text-secondary); padding-left: 3rem; font-size: 1rem; }
        
        .enterprise-stats {
            padding: 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;
            border-radius: var(--radius-lg); background: white;
            box-shadow: var(--shadow-lg); border: 1px solid var(--border-light);
        }
        
        .stat-box h3 { font-size: 3.5rem; font-weight: 800; margin-bottom: 0.5rem; }
        .stat-box p { font-size: 0.95rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); }

        /* Mentors */
        .mentors-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 3rem; margin-top: 5rem; }
        .mentor-card { text-align: center; width: 160px; }
        
        .mentor-avatar {
            width: 120px; height: 120px; border-radius: 50%;
            background: var(--bg-offwhite); margin: 0 auto 1.5rem;
            display: flex; align-items: center; justify-content: center;
            font-size: 3rem; border: 4px solid white;
            box-shadow: var(--shadow-md);
            position: relative; transition: var(--transition-smooth);
        }
        
        .mentor-card:hover .mentor-avatar { 
            transform: translateY(-10px); 
            box-shadow: 0 20px 30px rgba(255,193,7,0.2);
            border-color: var(--yellow-light);
        }
        
        .mentor-badge {
            position: absolute; bottom: 0; right: 5px;
            background: var(--yellow-gradient); color: #FFF;
            width: 32px; height: 32px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            border: 3px solid white; box-shadow: var(--shadow-sm);
        }
        
        .mentor-name { font-weight: 700; font-size: 1.1rem; margin-bottom: 0.25rem; }
        .mentor-role { font-size: 0.9rem; color: var(--text-secondary); font-weight: 500; }

        /* Testimonials */
        .testimonials-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-top: 4rem; }
        
        .testimonial-card { padding: 3rem; display: flex; flex-direction: column; justify-content: space-between; height: 100%; }
        
        .testimonial-quote { font-size: 1.4rem; font-weight: 500; line-height: 1.6; margin-bottom: 2.5rem; color: var(--text-main); font-style: italic; }
        .testimonial-author { display: flex; align-items: center; gap: 1.25rem; }
        
        .author-avatar {
            width: 56px; height: 56px; border-radius: 50%;
            background: var(--yellow-light); display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
        }
        
        .author-info h5 { font-weight: 700; font-size: 1.05rem; }
        .author-info p { font-size: 0.9rem; color: var(--text-secondary); font-weight: 500; }

        /* Credentials */
        .credentials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
        .credentials-list { margin-top: 3rem; display: flex; flex-direction: column; gap: 1.5rem; }
        
        .credential-item {
            display: flex; align-items: center; gap: 1.5rem; padding: 2rem;
        }
        
        .credential-icon { color: #D97706; width: 32px; height: 32px; }
        
        .credential-visual {
            padding: 2rem 0; display: flex; justify-content: center; position: relative;
        }
        
        .certificate-card {
            background: white; border: 12px solid var(--bg-offwhite); outline: 1px solid var(--border-light); outline-offset: -16px;
            border-radius: 4px; padding: 3rem 2rem; width: 100%; max-width: 600px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.1);
            position: relative; overflow: hidden;
            transition: var(--transition-smooth);
            text-align: center;
        }

        .certificate-card:hover {
            transform: scale(1.03) rotate(1deg);
            box-shadow: 0 30px 60px rgba(255,193,7,0.15);
        }
        
        .cert-header { display: flex; flex-direction: column; align-items: center; margin-bottom: 2rem; }
        .cert-logo { font-weight: 800; letter-spacing: 2px; font-size: 1.5rem; margin-bottom: 0.5rem; }

        /* FAQ */
        .faq-container { max-width: 800px; margin: 4rem auto 0; }
        .faq-item { border-bottom: 1px solid var(--border-light); }
        
        .faq-question {
            width: 100%; text-align: left; background: none; border: none;
            padding: 2rem 0; font-size: 1.2rem; font-weight: 600;
            color: var(--text-main); display: flex; justify-content: space-between;
            align-items: center; cursor: pointer; transition: var(--transition-smooth);
        }
        
        .faq-question:hover { color: #D97706; }
        
        .faq-icon {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--bg-offwhite); display: flex; align-items: center; justify-content: center;
            color: var(--text-main); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        .faq-question[aria-expanded="true"] .faq-icon { transform: rotate(135deg); background: var(--yellow-light); color: #D97706; }
        
        .faq-answer {
            padding: 0 0 2rem 0; color: var(--text-secondary); font-size: 1.05rem; line-height: 1.7; 
            max-height: 0; overflow: hidden; opacity: 0; transition: all 0.4s ease;
        }
        
        .faq-question[aria-expanded="true"] + .faq-answer { max-height: 300px; opacity: 1; }

        /* Final CTA */
        .final-cta { text-align: center; border-bottom: 1px solid var(--border-light); }
        .final-cta-box {
            background: var(--yellow-gradient);
            border-radius: var(--radius-lg);
            padding: 6rem 3rem;
            color: white;
            box-shadow: 0 20px 40px rgba(255,193,7,0.2);
            position: relative;
            overflow: hidden;
        }
        
        .final-cta-box h2 { color: white; margin-bottom: 1.5rem; }
        .final-cta-box p { color: rgba(255,255,255,0.9); font-size: 1.2rem; max-width: 600px; margin: 0 auto 3rem; }

        /* Footer */
        footer { padding: 5rem 0 2rem; background: var(--bg-offwhite); }
        .footer-brand p { color: var(--text-secondary); font-size: 0.95rem; margin-top: 1.5rem; max-width: 320px; line-height: 1.7; }
        .footer-links h4 { font-size: 1rem; font-weight: 700; margin-bottom: 2rem; color: var(--text-main); }
        .footer-links a { display: block; color: var(--text-secondary); text-decoration: none; font-size: 0.95rem; margin-bottom: 1rem; font-weight: 500; transition: color 0.2s; }
        .footer-links a:hover { color: #D97706; transform: translateX(4px); display: inline-block; }
        
        .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; }
        
        .mentors-header { display: flex; justify-content: space-between; align-items: flex-end; }
        
        .footer-bottom {
            margin-top: 5rem; padding-top: 2rem; border-top: 1px solid var(--border-light);
            display: flex; justify-content: space-between; color: var(--text-muted); font-size: 0.9rem;
        }

        @media (max-width: 992px) {
            .section.hero, .enterprise-grid, .credentials-grid { grid-template-columns: 1fr; gap: 3rem; }
            .section.hero { align-items: flex-start; padding-top: 7rem; min-height: auto; padding-bottom: 4rem; }
            .hero-content { text-align: left; padding-top: 0; }
            .hero-subtitle { margin: 0 0 2rem 0; font-size: 1.05rem; line-height: 1.5; color: var(--text-secondary); max-width: 100%; }
            .hero-actions { justify-content: flex-start; flex-direction: column; width: 100%; gap: 1rem; }
            .hero-actions .btn { width: 100%; }
            .hero-stats { justify-content: flex-start; gap: 1rem; flex-wrap: wrap; text-align: left; margin-top: 2rem; border-top: 1px solid var(--border-light); padding-top: 1.5rem; }
            .hero-stats > div { flex: 1 1 calc(50% - 1rem); min-width: 120px; }
            .hero-stats strong { font-size: 1.5rem; display: block; color: var(--text-main); }
            .hero-card { margin: 0 auto; max-width: 100%; }
            .testimonials-grid { grid-template-columns: 1fr; }
            .footer-grid { grid-template-columns: 1fr 1fr; }
            .section { padding: 4rem 0; }
        }
        @media (max-width: 768px) {
            body { 
                /* App-like feel for mobile */
                -webkit-tap-highlight-color: transparent; 
                overflow-x: hidden;
                width: 100%;
            }
            .container { padding: 0 1rem; overflow-x: hidden; }
            nav { padding: 1rem; }
            nav.scrolled { padding: 0.75rem 1rem; }
            .nav-links { display: none; }
            .nav-actions { display: flex; align-items: center; }
            .nav-actions .btn-primary { display: none; }
            .nav-actions .btn-outline { padding: 0.5rem 1.25rem !important; border: 1px solid var(--border-light) !important; border-radius: 50px; font-size: 0.85rem; }
            .stat-box h3 { font-size: 2.5rem; }
            .enterprise-stats { padding: 1.5rem; gap: 1.5rem; grid-template-columns: 1fr 1fr; }
            .mentors-header { flex-direction: column; align-items: center; text-align: center; gap: 1.5rem; }
            .mentors-header p { text-align: center; margin: 0 auto; }
            .mentors-row { gap: 1.5rem; }
            .mentor-card { width: calc(50% - 0.75rem); }
            .mentor-avatar { width: 80px; height: 80px; font-size: 2rem; }
            .footer-grid { grid-template-columns: 1fr; }
            .footer-bottom { flex-direction: column; gap: 1.5rem; text-align: center; }
            
            /* Add Mobile App Bottom Nav for the "App Feel" */
            .mobile-bottom-nav {
                display: flex;
            }
        }
        
        .mobile-bottom-nav {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: #ffffff;
            border-top: 1px solid #f1f5f9;
            z-index: 1000;
            justify-content: space-around;
            padding: 0.75rem 0;
            padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));
        }
        
        .mobile-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            color: #000000;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            flex: 1;
        }
        
        .mobile-nav-item.active {
            color: #82b1ff;
        }
        .mobile-nav-item.active i {
            color: #82b1ff;
        }
        
        /* Prevent body scroll when nav is present */
        @media (max-width: 768px) {
            body { padding-bottom: 70px; }
        }
        /* =========================================
           Bee Chatbot Widget Styles
           ========================================= */
        .bee-chat-widget {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .bee-chat-fab {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #FFC107;
            border: none;
            cursor: pointer;
            box-shadow: 0 10px 25px -5px rgba(212, 170, 0, 0.4), 0 8px 10px -6px rgba(212, 170, 0, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .bee-chat-fab:hover {
            transform: scale(1.1);
        }

        .bee-chat-window {
            width: 350px;
            height: 500px;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            margin-bottom: 1rem;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            transform-origin: bottom right;
            animation: beeChatOpen 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes beeChatOpen {
            from { opacity: 0; transform: scale(0.9) translateY(20px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .bee-chat-header {
            background: #FFC107;
            padding: 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .bee-chat-messages {
            flex: 1;
            padding: 1rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            background: #f8fafc;
        }

        .bee-message {
            display: flex;
            max-width: 85%;
        }

        .bee-message-bot {
            align-self: flex-start;
        }

        .bee-message-user {
            align-self: flex-end;
        }

        .bee-bubble {
            padding: 0.75rem 1rem;
            border-radius: 12px;
            font-size: 0.9rem;
            line-height: 1.4;
            word-wrap: break-word;
        }

        .bee-message-bot .bee-bubble {
            background: #ffffff;
            color: #0f172a;
            border: 1px solid #e2e8f0;
            border-bottom-left-radius: 4px;
        }

        .bee-message-user .bee-bubble {
            background: #0f172a;
            color: #ffffff;
            border-bottom-right-radius: 4px;
        }

        .bee-chat-input-area {
            padding: 1rem;
            background: #ffffff;
            border-top: 1px solid #e2e8f0;
            display: flex;
            gap: 0.5rem;
        }

        .bee-chat-input-area input {
            flex: 1;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
            background: #f8fafc;
            color: #0f172a;
        }

        .bee-chat-input-area input:focus {
            border-color: #FFC107;
        }

        .bee-chat-input-area button {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #FFC107;
            border: none;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.2s;
        }

        .bee-chat-input-area button:hover {
            opacity: 0.9;
        }

        .bee-typing-dot {
            width: 6px;
            height: 6px;
            background: #64748b;
            border-radius: 50%;
            display: inline-block;
            animation: beeTyping 1.4s infinite ease-in-out both;
        }

        .bee-typing-dot:nth-child(1) { animation-delay: -0.32s; }
        .bee-typing-dot:nth-child(2) { animation-delay: -0.16s; }

        @keyframes beeTyping {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }
    </style>
