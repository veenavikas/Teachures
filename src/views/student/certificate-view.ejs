<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Certificate of Completion | <%= course.title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #e2e8f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Inter', sans-serif;
            color: #0F172A;
        }

        .certificate-wrapper {
            position: relative;
        }

        .certificate {
            background-color: #ffffff;
            width: 1050px;
            height: 750px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            position: relative;
            overflow: hidden;
            display: flex;
            border: 1px solid #cbd5e1;
        }

        .black-panel {
            width: 330px;
            background-color: #000000;
            height: 100%;
            position: relative;
            z-index: 1;
        }

        .white-panel {
            flex: 1;
            padding: 60px 80px 40px 100px;
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
        }

        .starburst {
            position: absolute;
            left: 330px;
            top: 70%;
            transform: translate(-50%, -50%);
            width: 500px;
            height: 500px;
            z-index: 10;
            pointer-events: none;
        }

        .starburst svg {
            width: 100%;
            height: 100%;
            fill: #F6F3E6;
        }

        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 50px;
        }

        .logo img {
            height: 50px;
        }

        .badge svg {
            width: 90px;
            height: 90px;
        }

        .congrats-text {
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 15px;
            color: #1e293b;
        }

        .course-title {
            font-size: 2.8rem;
            font-weight: 500;
            line-height: 1.2;
            margin-bottom: 40px;
            color: #0f172a;
        }

        .course-date {
            font-size: 1.15rem;
            font-weight: 600;
            margin-bottom: 50px;
            color: #334155;
        }

        .certify-text {
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 15px;
            color: #1e293b;
        }

        .student-name {
            font-family: 'Great Vibes', cursive;
            font-size: 4.5rem;
            color: #0F172A;
            margin-bottom: auto;
            line-height: 1;
            padding-left: 5px;
        }

        .footer-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 40px;
        }

        .signature-block {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .signature-mock {
            font-family: 'Great Vibes', cursive;
            font-size: 2.8rem;
            color: #334155;
            margin-bottom: -15px;
        }

        .name {
            font-weight: 700;
            font-size: 1.1rem;
            color: #0f172a;
        }

        .title {
            font-size: 0.9rem;
            color: #475569;
        }

        .bottom-meta {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 35px;
        }

        .cert-id {
            font-size: 0.85rem;
            color: #64748b;
        }

        .cert-id strong {
            color: #0f172a;
        }

        .qr-code {
            width: 55px;
            height: 55px;
        }

        @media print {
            body { background: white; margin: 0; padding: 0; }
            .certificate-wrapper { box-shadow: none; padding: 0; width: 100%; }
            .no-print { display: none; }
            @page { size: landscape; margin: 0; }
            .certificate { border: none; box-shadow: none; width: 100vw; height: 100vh; flex-direction: row; }
            .black-panel { width: 330px; height: 100%; }
            .white-panel { padding: 60px 80px 40px 100px; }
            .starburst { left: 330px; top: 70%; transform: translate(-50%, -50%); width: 500px; height: 500px; }
            .footer-row { flex-direction: row; align-items: flex-end; }
            .signature-block { text-align: left; }
            .signature-block:last-child { text-align: right; }
            .bottom-meta { flex-direction: row; align-items: flex-end; }
        }

        @media (max-width: 768px) {
            body { padding: 1rem; align-items: flex-start; }
            .certificate-wrapper { width: 100%; }
            .certificate {
                width: 100%;
                height: auto;
                flex-direction: column;
                border-radius: 12px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            }
            .black-panel {
                width: 100%;
                height: 120px;
            }
            .white-panel {
                padding: 40px 20px 30px;
            }
            .starburst {
                top: 120px;
                left: 50%;
                width: 250px;
                height: 250px;
            }
            .logo img { height: 40px; }
            .badge svg { width: 60px; height: 60px; }
            .header-row { margin-bottom: 30px; }
            .course-title { font-size: 1.8rem; margin-bottom: 20px; }
            .student-name { font-size: 2.8rem; margin-bottom: 30px; }
            .footer-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 20px;
            }
            .signature-block { text-align: left !important; }
            .bottom-meta {
                flex-direction: column;
                align-items: flex-start;
                gap: 20px;
                margin-top: 20px;
            }
            .print-btn {
                bottom: 20px;
                top: auto;
                right: 20px;
                left: 20px;
                text-align: center;
            }
        }

        .print-btn {
            position: fixed;
            top: 20px;
            right: 20px;
            background: #0F172A;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            z-index: 1000;
        }
        .print-btn:hover { background: #334155; }
    </style>
</head>
<body>
    <button class="print-btn no-print" onclick="window.print()">Print / Save PDF</button>

    <div class="certificate-wrapper">
        <div class="certificate">
            <div class="black-panel"></div>
            
            <div class="starburst">
                <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                    <!-- 12-point star perfectly framing the boundary -->
                    <path d="M100,0 L109,66 L150,13 L125,75 L187,50 L134,91 L200,100 L134,109 L187,150 L125,125 L150,187 L109,134 L100,200 L91,134 L50,187 L75,125 L13,150 L66,109 L0,100 L66,91 L13,50 L75,75 L50,13 L91,66 Z" fill="#F6F3E6"/>
                </svg>
            </div>

            <div class="white-panel">
                <div class="header-row">
                    <div class="logo">
                        <img src="/images/teach.jpg" alt="Teachures Logo" onerror="this.src='https://placehold.co/200x60/ffffff/000000?text=TEACHURES'">
                    </div>
                    <div class="badge">
                        <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                            <!-- Premium yellow scalloped badge -->
                            <path d="M60 5 L68 15 L80 12 L85 24 L97 27 L97 40 L108 47 L103 58 L111 68 L100 75 L101 88 L89 91 L85 103 L73 100 L64 110 L54 102 L42 109 L35 98 L23 99 L20 87 L8 83 L12 71 L3 61 L11 51 L4 39 L15 33 L16 21 L28 19 L33 7 L44 12 Z" fill="#FDE047"/>
                            <circle cx="60" cy="60" r="40" fill="#EAB308"/>
                            <polygon points="60,35 66,50 82,50 69,60 74,75 60,65 46,75 51,60 38,50 54,50" fill="#FFFFFF"/>
                        </svg>
                    </div>
                </div>

                <div class="congrats-text">Congratulations on completing</div>
                <div class="course-title">[ <%= course.title %> ]</div>
                
                <div class="course-date">Course completed [ <%= new Date(certificate.issuedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %> ]</div>

                <div class="certify-text">This is to certify that</div>
                <div class="student-name">[ <%= user.name %> ]</div>

                <div class="footer-row">
                    <div class="signature-block">
                        <div class="signature-mock">[ <%= course.instructor.name %> ]</div>
                        <div class="name">[ <%= course.instructor.name %> ]</div>
                        <div class="title">Instructor, Teachures</div>
                    </div>
                    <div class="signature-block" style="text-align: right;">
                        <div class="signature-mock" style="padding-right: 10px;">John Harvard</div>
                        <div class="name">John Harvard</div>
                        <div class="title">Director, Teachures</div>
                    </div>
                </div>

                <div class="bottom-meta">
                    <div class="cert-id">Certificate Id: <strong>[ <%= certificate.verifyCode %> ]</strong></div>
                    <div class="qr-code">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=<%= process.env.APP_URL || 'http://localhost:3000' %>/verify/<%= certificate.verifyCode %>" alt="QR Code" style="width: 100%; height: 100%;">
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
