<div class="card" style="padding: 2rem;">
    <h2 style="margin-bottom: 1rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem;">Community Forums</h2>
    <p style="color: var(--color-gray-light); margin-bottom: 2rem;">Welcome to the community! Select a category to browse or start a new discussion.</p>

    <% if (categories.length === 0) { %>
        <p class="text-muted">No categories have been created yet.</p>
    <% } else { %>
        <div style="display: grid; gap: 1rem;">
            <% categories.forEach(cat => { %>
                <a href="/student/community/<%= cat.id %>" style="text-decoration: none; display: block; border: 1px solid var(--color-gray-mid); border-radius: 8px; padding: 1.5rem; transition: border-color 0.2s, background-color 0.2s; background: rgba(255,255,255,0.02);">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <h3 style="color: white; margin-bottom: 0.5rem;"><%= cat.name %></h3>
                            <p style="color: var(--color-gray-light); font-size: 0.9rem; margin: 0;"><%= cat.description || 'Discuss topics related to ' + cat.name %></p>
                        </div>
                        <div style="text-align: right;">
                            <span class="badge" style="background: rgba(var(--color-primary-rgb), 0.2); color: var(--color-primary); padding: 0.25rem 0.75rem; border-radius: 20px;">
                                <%= cat._count.topics %> Topics
                            </span>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    <% } %>
</div>
