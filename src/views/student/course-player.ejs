<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>
        <%= title %> | Teachures Player
    </title>

    <link
        href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,600;1,300&family=JetBrains+Mono&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css?v=lighttheme1">

    <style>
        body {
            margin: 0;
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            background-color: var(--color-black);
        }

        .player-header {
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            background-color: #111;
            border-bottom: 1px solid var(--color-gray-mid);
        }

        .player-main {
            flex: 1;
            display: flex;
            overflow: hidden;
        }

        .video-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            background-color: #000;
        }

        .video-container {
            width: 100%;
            aspect-ratio: 16/9;
            background-color: #000;
            position: relative;
        }

        /* Simulate Video.js Custom Theme */
        .vjs-custom {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-gray-mid);
        }

        .content-area {
            padding: 2rem;
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
            background-color: var(--color-black);
        }

        .sidebar-curriculum {
            width: 350px;
            background-color: var(--color-black);
            border-left: 1px solid var(--color-gray-mid);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--color-gray-mid);
        }

        .accordion {
            flex: 1;
            overflow-y: auto;
        }

        .section-header {
            padding: 1.25rem 1.5rem;
            background-color: var(--color-gray-dark);
            border-bottom: 1px solid var(--color-gray-mid);
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 600;
        }

        .lesson-item {
            padding: 1rem 1.5rem 1rem 3rem;
            border-bottom: 1px solid var(--color-gray-mid);
            background-color: var(--color-black);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: background 0.2s;
        }

        .lesson-item:hover {
            background-color: rgba(0,0,0,0.02);
        }

        .lesson-item.active {
            background-color: rgba(245, 197, 24, 0.05);
            border-left: 3px solid var(--color-primary);
            padding-left: calc(3rem - 3px);
        }

        .lesson-icon {
            width: 16px;
            height: 16px;
        }

        /* Watermark Canvas overlay - replaced with robust DOM watermark */
        #wm-anti-piracy {
            position: absolute;
            pointer-events: none;
            z-index: 2147483647;
            /* Max z-index */
            color: rgba(0,0,0,0.25);
            font-family: 'JetBrains Mono', monospace;
            font-size: 14px;
            font-weight: bold;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);
            white-space: nowrap;
            user-select: none;
            mix-blend-mode: overlay;
            transition: top 2s ease-in-out, left 2s ease-in-out;
        }
    </style>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

    <header class="player-header">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="/student/dashboard" class="text-white" style="text-decoration: none;"><i data-lucide="arrow-left"
                    style="width: 20px;"></i></a>
            <span style="font-family: var(--font-heading); font-weight: 700; font-size: 1.1rem;">
                <%= course.title %>
            </span>
        </div>

        <div style="display: flex; align-items: center; gap: 1rem;">
            <div
                style="width: 150px; height: 6px; background: var(--color-gray-mid); border-radius: 3px; overflow: hidden;">
                <div style="width: 12%; height: 100%; background: var(--color-primary);"></div>
            </div>
            <span class="text-white" style="font-size: 0.85rem; font-weight: 700; margin-right: 1rem;">12%
                Complete</span>
            <button class="btn btn-outline" onclick="toggleWhiteboard()"
                style="padding: 0.5rem 1rem; font-size: 0.8rem; margin-right: 0.5rem;">
                <i data-lucide="pen-tool" style="width: 14px; margin-right: 5px;"></i> Whiteboard
            </button>
            <button class="btn btn-outline" onclick="openReviewModal()"
                style="padding: 0.5rem 1rem; font-size: 0.8rem;">
                <i data-lucide="star" style="width: 14px; margin-right: 5px;"></i> Leave Review
            </button>
        </div>
    </header>

    <div class="player-main">

        <div class="video-area">
            <div class="video-container">
                <!-- Main Player Area -->
                <div class="vjs-custom" id="videoWrapper">
                    <% if (activeLesson && activeLesson.isLocked) { %>
                        <div style="text-align: center; color: var(--color-gray-mid);">
                            <% if (activeLesson.lockReason === 'drip_locked') { %>
                                <i data-lucide="clock" style="width: 48px; height: 48px; margin-bottom: 1rem;"></i>
                                <h3>Available Soon</h3>
                                <p>This content unlocks on <%= new Date(activeLesson.unlockDate).toLocaleDateString() %></p>
                            <% } else { %>
                                <i data-lucide="lock" style="width: 48px; height: 48px; margin-bottom: 1rem;"></i>
                                <h3>Content Locked</h3>
                                <p>Please complete previous lessons to unlock.</p>
                            <% } %>
                        </div>
                    <% } else if (activeLesson && activeLesson.type === 'LIVE') { %>
                        <div style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; height: 100%; color: var(--color-white); padding: 2rem;">
                            <i data-lucide="radio" style="width: 64px; height: 64px; margin-bottom: 1rem; color: var(--color-primary);"></i>
                            <h2 style="margin-bottom: 0.5rem;">Live Session</h2>
                            <p style="color: var(--color-gray-light); margin-bottom: 2rem; max-width: 500px;">
                                This lesson is a live session. Please join at the scheduled time using the link below.
                            </p>
                            
                            <% if (activeLesson.liveStartTime) { %>
                                <div style="background: rgba(0,0,0,0.05); padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid var(--color-gray-mid);">
                                    <p style="margin: 0; font-size: 0.9rem; color: var(--color-gray-light); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">Scheduled Start Time</p>
                                    <h3 style="margin: 0; font-family: var(--font-mono); color: var(--color-primary);">
                                        <%= new Date(activeLesson.liveStartTime).toLocaleString() %>
                                    </h3>
                                </div>
                            <% } %>
                            
                            <% if (activeLesson.liveUrl) { %>
                                <a href="<%= activeLesson.liveUrl %>" target="_blank" class="btn btn-primary" style="font-size: 1.1rem; padding: 1rem 2rem; display: inline-flex; align-items: center; gap: 10px;">
                                    <i data-lucide="external-link"></i> Join Live Meeting
                                </a>
                                <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--color-gray-mid);">
                                    Clicking the button will open Zoom, Meet, or the designated platform in a new tab.
                                </p>
                            <% } else { %>
                                <p class="text-danger">Live meeting link has not been provided by the instructor yet.</p>
                            <% } %>

                            <button id="markCompleteLiveBtn" class="btn btn-outline" style="margin-top: 3rem; color: var(--color-success); border-color: var(--color-success);" onclick="markActiveLessonComplete()">
                                <i data-lucide="check-circle" style="margin-right: 8px;"></i> Mark as Complete
                            </button>
                        </div>
                    <% } else if (activeLesson && activeLesson.type === 'ASSIGNMENT') { %>
                        <div style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; height: 100%; color: var(--color-white); padding: 2rem;">
                            <i data-lucide="clipboard" style="width: 64px; height: 64px; margin-bottom: 1rem; color: var(--color-primary);"></i>
                            <h2 style="margin-bottom: 0.5rem;">Assignment</h2>
                            <% if (activeLesson.assignment) { %>
                                <p style="color: var(--color-gray-light); margin-bottom: 2rem; max-width: 600px; text-align: left;">
                                    <%= activeLesson.assignment.description %>
                                </p>
                                <% if (activeLesson.assignment.deadline) { %>
                                    <div style="background: rgba(0,0,0,0.05); padding: 1rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid var(--color-gray-mid);">
                                        <p style="margin: 0; font-size: 0.9rem; color: var(--color-warning);">Deadline: <%= new Date(activeLesson.assignment.deadline).toLocaleString() %></p>
                                    </div>
                                <% } %>

                                <% const submission = activeLesson.assignment.submissions && activeLesson.assignment.submissions[0]; %>
                                <% if (submission) { %>
                                    <div style="background: rgba(16, 185, 129, 0.1); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--color-success); margin-bottom: 1rem;">
                                        <h3 style="color: var(--color-success); margin-bottom: 0.5rem;">Assignment Submitted</h3>
                                        <p>Status: <%= submission.status %></p>
                                        <% if (submission.grade !== null) { %>
                                            <p>Grade: <%= submission.grade %>%</p>
                                        <% } %>
                                        <% if (submission.feedback) { %>
                                            <p style="margin-top: 0.5rem; font-style: italic;">Feedback: <%= submission.feedback %></p>
                                        <% } %>
                                        <a href="<%= submission.fileUrl %>" target="_blank" class="text-primary" style="margin-top: 1rem; display: inline-block;">View Submitted File</a>
                                    </div>
                                <% } else { %>
                                    <div style="width: 100%; max-width: 500px; background: var(--color-black); padding: 2rem; border-radius: 8px; border: 1px solid var(--color-gray-mid); text-align: left;">
                                        <h3 style="margin-bottom: 1rem;">Submit Your Assignment</h3>
                                        <form id="assignmentSubmitForm">
                                            <input type="hidden" id="assignId" value="<%= activeLesson.assignment.id %>">
                                            <div class="form-group" style="margin-bottom: 1rem;">
                                                <label class="form-label" style="display:block; margin-bottom: 0.5rem;">Upload File (PDF, DOCX, ZIP)</label>
                                                <input type="file" id="assignFile" class="form-control" required style="background: white; color: black; padding: 0.5rem;">
                                            </div>
                                            <button type="submit" class="btn btn-primary" style="width: 100%;">Submit Assignment</button>
                                        </form>
                                    </div>
                                <% } %>
                            <% } else { %>
                                <p class="text-danger">Assignment details are missing.</p>
                            <% } %>
                        </div>
                    <% } else { %>
                        <% if (preSignedVideoUrl) { %>
                           <video id="courseVideoPlayer" controls style="width: 100%; max-height: 70vh; background: #000; display: block;" controlsList="nodownload">
                               <source src="<%= preSignedVideoUrl %>" type="video/mp4">
                               Your browser does not support HTML video.
                           </video>
                        <% } else { %>
                           <div style="text-align: center; color: var(--color-gray-mid); padding: 4rem;">
                               <i data-lucide="video-off" style="width: 48px; height: 48px; margin-bottom: 1rem;"></i>
                               <h3>No Video Available</h3>
                               <p>This lesson does not contain a video.</p>
                           </div>
                        <% } %>
                    <% } %>
                </div>
            </div>

            <div class="content-area">
                <h2 style="margin-bottom: 1rem;">1. Introduction to the Platform</h2>

                <div style="display: flex; gap: 1rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem; margin-bottom: 2rem;">
                    <button onclick="switchTab('overview')" id="btn-overview"
                        style="background:none; border:none; color: var(--color-primary); font-family: var(--font-heading); font-weight: 700; font-size: 1.1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--color-primary); cursor: pointer;">Overview</button>
                    <button onclick="switchTab('qna'); loadQnA();" id="btn-qna"
                        style="background:none; border:none; color: var(--color-gray-light); font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; padding-bottom: 0.5rem; cursor: pointer;">Q&A</button>
                    <button onclick="switchTab('ai')" id="btn-ai"
                        style="background:none; border:none; color: var(--color-gray-light); font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; padding-bottom: 0.5rem; cursor: pointer;"><i data-lucide="bot" style="width: 18px; margin-bottom: -3px;"></i> AI Tutor</button>
                    <button onclick="switchTab('notes')" id="btn-notes"
                        style="background:none; border:none; color: var(--color-gray-light); font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; padding-bottom: 0.5rem; cursor: pointer;">Notes</button>
                    <button onclick="switchTab('resources')" id="btn-resources"
                        style="background:none; border:none; color: var(--color-gray-light); font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; padding-bottom: 0.5rem; cursor: pointer;">Resources</button>
                    <button onclick="switchTab('announcements')" id="btn-announcements"
                        style="background:none; border:none; color: var(--color-gray-light); font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; padding-bottom: 0.5rem; cursor: pointer;">Announcements</button>
                    <% if (activeLesson && !activeLesson.isLocked && !activeLesson.isCompleted) { %>
                        <button id="markCompleteBtn" onclick="markLessonComplete('<%= activeLesson.id %>')" class="btn btn-primary" style="display: none; margin-left: auto; font-size: 0.9rem; padding: 0.4rem 1rem;">Mark as Complete</button>
                    <% } else if (activeLesson && activeLesson.isCompleted) { %>
                        <div style="margin-left: auto; color: #10B981; font-weight: bold; display: flex; align-items: center; gap: 0.5rem;"><i data-lucide="check-circle" style="width: 20px;"></i> Completed</div>
                    <% } %>
                </div>

                <div id="tab-overview">
                    <p class="text-white" style="line-height: 1.8; white-space: pre-wrap;">
                        <%= activeLesson ? (activeLesson.content || 'No content provided.') : 'Select a lesson to view.' %>
                    </p>
                </div>

                <div id="tab-qna" style="display: none;">
                    <h3 style="color: var(--color-white); margin-bottom: 1rem;">Course Q&A</h3>
                    <form id="qnaForm" style="margin-bottom: 2rem;">
                        <textarea id="qnaQuestion" rows="3" style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid var(--color-gray-mid); color: var(--color-white); padding: 0.75rem; border-radius: 4px; margin-bottom: 0.5rem;" placeholder="Ask a question..." required></textarea>
                        <button type="submit" class="btn btn-primary">Post Question</button>
                    </form>
                    <div id="qnaList">
                        <!-- Q&A Items will be loaded here -->
                        <p style="color: var(--color-gray-light);">Loading questions...</p>
                    </div>
                </div>

                <div id="tab-ai" style="display: none;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <h3 style="color: var(--color-white); margin: 0;"><i data-lucide="bot" style="margin-right: 5px;"></i> AI Teaching Assistant</h3>
                        <span class="badge" style="background: rgba(144, 102, 255, 0.2); color: #9066FF; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.75rem;">Powered by Groq</span>
                    </div>
                    
                    <div id="aiChatWindow" style="background: rgba(0,0,0,0.02); border: 1px solid var(--color-gray-mid); border-radius: 8px; height: 300px; overflow-y: auto; padding: 1rem; margin-bottom: 1rem; display: flex; flex-direction: column; gap: 1rem;">
                        <div style="align-self: flex-start; background: rgba(0,0,0,0.1); padding: 0.75rem 1rem; border-radius: 8px; border-bottom-left-radius: 0; color: var(--color-white); max-width: 80%;">
                            Hello! I'm your AI Tutor for this course. Do you have any questions about this lesson?
                        </div>
                    </div>

                    <form id="aiChatForm" style="display: flex; gap: 0.5rem;">
                        <input type="text" id="aiQuestionInput" style="flex: 1; background: rgba(0,0,0,0.05); border: 1px solid var(--color-gray-mid); color: var(--color-white); padding: 0.75rem; border-radius: 4px;" placeholder="Ask me anything about the course..." required>
                        <button type="submit" class="btn btn-primary" id="aiSubmitBtn" style="white-space: nowrap;">Send</button>
                    </form>
                </div>

                <div id="tab-notes" style="display: none;">
                    <h3 style="color: var(--color-white); margin-bottom: 1rem;">My Notes</h3>
                    <form id="noteForm" style="margin-bottom: 2rem;">
                        <textarea id="noteContent" rows="3" style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid var(--color-gray-mid); color: var(--color-white); padding: 0.75rem; border-radius: 4px; margin-bottom: 0.5rem;" placeholder="Type your note here..." required></textarea>
                        <div style="display: flex; gap: 1rem; align-items: center;">
                            <button type="button" class="btn btn-outline" id="captureTimeBtn" style="display: <%= activeLesson && activeLesson.type === 'VIDEO' ? 'inline-block' : 'none' %>;">
                                <i data-lucide="clock" class="icon-sm"></i> Capture Video Time
                            </button>
                            <span id="noteTimeDisplay" style="color: var(--color-primary); font-weight: bold; display: none;"></span>
                            <button type="submit" class="btn btn-primary" style="margin-left: auto;">Save Note</button>
                        </div>
                    </form>
                    <div id="notesList" style="display: flex; flex-direction: column; gap: 1rem;">
                        <% if (notes && notes.length > 0) { %>
                            <% notes.forEach(n => { %>
                                <div style="background: rgba(0,0,0,0.05); padding: 1rem; border-radius: 8px; border: 1px solid var(--color-gray-mid); position: relative;">
                                    <button class="btn-delete-note" onclick="deleteNote('<%= n.id %>')" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: #ef4444; cursor: pointer;">
                                        <i data-lucide="trash-2" class="icon-sm"></i>
                                    </button>
                                    <% if (n.timestamp !== null) { %>
                                        <button class="btn-seek" onclick="seekVideo(<%= n.timestamp %>)" style="background: rgba(37, 99, 235, 0.2); border: none; color: var(--color-primary); padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem; font-weight: bold; cursor: pointer; margin-bottom: 0.5rem; display: inline-block;">
                                            <i data-lucide="play-circle" class="icon-sm" style="vertical-align: middle;"></i> 
                                            <%= Math.floor(n.timestamp / 60) %>:<%= (n.timestamp % 60).toString().padStart(2, '0') %>
                                        </button>
                                    <% } %>
                                    <p style="color: var(--color-white); margin: 0; white-space: pre-wrap;"><%= n.content %></p>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p style="color: var(--color-gray-light);">No notes taken yet for this lesson.</p>
                        <% } %>
                    </div>
                </div>

                <div id="tab-resources" style="display: none;">
                    <h3 style="color: var(--color-white); margin-bottom: 1rem;">Lesson Resources</h3>
                    <% 
                       let attachments = [];
                       if (activeLesson && activeLesson.attachments) {
                           try { attachments = typeof activeLesson.attachments === 'string' ? JSON.parse(activeLesson.attachments) : activeLesson.attachments; } catch(e) {}
                       }
                    %>
                    <% if (attachments && attachments.length > 0) { %>
                        <div style="display: flex; flex-direction: column; gap: 1rem;">
                            <% attachments.forEach(att => { %>
                                <a href="<%= att.url %>" target="_blank" style="display: flex; align-items: center; padding: 1rem; background: rgba(0,0,0,0.05); border: 1px solid var(--color-gray-mid); border-radius: 8px; text-decoration: none; color: var(--color-white);">
                                    <div style="background: rgba(37, 99, 235, 0.2); color: var(--color-primary); padding: 0.5rem; border-radius: 4px; margin-right: 1rem;">
                                        <i data-lucide="file-down"></i>
                                    </div>
                                    <div>
                                        <strong style="display: block;"><%= att.name || 'Download File' %></strong>
                                        <span style="color: var(--color-gray-light); font-size: 0.85rem;">Click to download</span>
                                    </div>
                                </a>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <p style="color: var(--color-gray-light);">No additional resources provided for this lesson.</p>
                    <% } %>
                </div>

                <div id="tab-announcements" style="display: none;">
                    <h3 style="color: var(--color-white); margin-bottom: 1rem;">Course Announcements</h3>
                    <% if (announcements && announcements.length > 0) { %>
                        <div style="display: flex; flex-direction: column; gap: 1rem;">
                            <% announcements.forEach(ann => { %>
                                <div style="background: rgba(37, 99, 235, 0.1); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--color-primary);">
                                    <h4 style="margin-bottom: 0.5rem; color: var(--color-primary);"><%= ann.title %></h4>
                                    <p style="color: var(--color-white); margin: 0; white-space: pre-wrap;"><%= ann.content %></p>
                                    <small style="color: var(--color-gray-light); display: block; margin-top: 1rem;"><%= new Date(ann.createdAt).toLocaleDateString() %></small>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <p style="color: var(--color-gray-light);">No announcements yet.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="sidebar-curriculum">
            <div class="sidebar-header">
                <h3 style="font-size: 1.1rem; margin: 0;">Course Content</h3>
            </div>

            <div class="accordion">
                <% if(course.sections && course.sections.length> 0) { %>
                    <% course.sections.forEach((section, sIdx)=> { %>
                        <div class="section-header">
                            <span>Section <%= sIdx + 1 %>: <%= section.title %></span>
                            <i data-lucide="chevron-down" class="icon-sm"></i>
                        </div>

                        <div class="section-body">
                            <% if(section.lessons && section.lessons.length> 0) { %>
                                <% section.lessons.forEach((lesson, lIdx)=> { %>
                                    <% const isActive = activeLesson && activeLesson.id === lesson.id; %>
                                    <div class="lesson-item <%= isActive ? 'active' : '' %>"
                                         style="<%= lesson.isLocked ? 'cursor: not-allowed; opacity: 0.6;' : 'cursor: pointer;' %>"
                                         <% if (!lesson.isLocked) { %> onclick="window.location.href='?lessonId=<%= lesson.id %>'" <% } %>>
                                        <% if (lesson.isLocked) { %>
                                            <% if (lesson.lockReason === 'drip_locked') { %>
                                                <i data-lucide="clock" class="text-muted lesson-icon" title="Unlocks <%= new Date(lesson.unlockDate).toLocaleDateString() %>"></i>
                                            <% } else { %>
                                                <i data-lucide="lock" class="text-muted lesson-icon"></i>
                                            <% } %>
                                        <% } else if (lesson.isCompleted) { %>
                                            <i data-lucide="check-circle" class="text-success lesson-icon" style="color: #10B981;"></i>
                                        <% } else if (isActive) { %>
                                            <i data-lucide="play-circle" class="text-primary lesson-icon"></i>
                                        <% } else { %>
                                            <i data-lucide="circle" class="text-muted lesson-icon"></i>
                                        <% } %>
                                        <span class="<%= isActive ? 'text-white' : 'text-muted' %>" style="font-size: 0.9rem; display: flex; flex-direction: column;">
                                            <span><%= lIdx + 1 %>. <%= lesson.title %></span>
                                            <% if (lesson.lockReason === 'drip_locked') { %>
                                                <small style="color: var(--color-gray-mid); font-size: 0.75rem;">Unlocks <%= new Date(lesson.unlockDate).toLocaleDateString() %></small>
                                            <% } %>
                                        </span>
                                    </div>
                                    <% }) %>
                                        <% } %>
                        </div>
                        <% }) %>
                            <% } %>
            </div>
        </div>

    </div>

    <!-- Review Modal -->
    <div id="reviewModal" class="modal"
        style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 9999; align-items: center; justify-content: center;">
        <div class="card" style="width: 400px; padding: 2rem; position: relative;">
            <button onclick="closeReviewModal()"
                style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--color-gray-light); cursor: pointer;">
                <i data-lucide="x"></i>
            </button>
            <h3 style="margin-bottom: 1.5rem; font-family: var(--font-heading);">Rate this Course</h3>

            <form id="reviewForm">
                <div style="margin-bottom: 1.5rem; display: flex; gap: 0.5rem; justify-content: center;"
                    id="starRating">
                    <i data-lucide="star" data-rating="1"
                        style="cursor: pointer; width: 32px; height: 32px; color: var(--color-gray-mid);"></i>
                    <i data-lucide="star" data-rating="2"
                        style="cursor: pointer; width: 32px; height: 32px; color: var(--color-gray-mid);"></i>
                    <i data-lucide="star" data-rating="3"
                        style="cursor: pointer; width: 32px; height: 32px; color: var(--color-gray-mid);"></i>
                    <i data-lucide="star" data-rating="4"
                        style="cursor: pointer; width: 32px; height: 32px; color: var(--color-gray-mid);"></i>
                    <i data-lucide="star" data-rating="5"
                        style="cursor: pointer; width: 32px; height: 32px; color: var(--color-gray-mid);"></i>
                </div>
                <input type="hidden" id="ratingInput" name="rating" value="0" required>

                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label style="display: block; margin-bottom: 0.5rem; color: var(--color-gray-light);">Your Review
                        (Optional)</label>
                    <textarea id="reviewTextInput" rows="4"
                        style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid var(--glass-border); color: var(--color-white); padding: 0.75rem; border-radius: 8px;"
                        placeholder="What did you think of the course?"></textarea>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;" id="submitReviewBtn">Submit
                    Review</button>
            </form>
        </div>
    </div>

    <!-- Floating Whiteboard -->
    <div id="whiteboardPanel" class="card"
        style="display: none; position: fixed; top: 100px; right: 50px; width: 600px; height: 450px; background: rgba(15, 15, 15, 0.95); border: 1px solid var(--glass-border); box-shadow: 0 8px 32px rgba(0,0,0,0.5); z-index: 10000; flex-direction: column; border-radius: 12px; overflow: hidden; backdrop-filter: blur(10px);">
        <!-- Whiteboard Header (Draggable) -->
        <div id="whiteboardHeader" style="padding: 0.75rem 1rem; background: rgba(0,0,0,0.05); border-bottom: 1px solid var(--color-gray-mid); display: flex; justify-content: space-between; align-items: center; cursor: grab;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <i data-lucide="pen-tool" class="text-primary"></i>
                <span style="font-weight: 600; color: var(--color-white);">Scratchpad</span>
            </div>
            <button onclick="toggleWhiteboard()" style="background: none; border: none; color: var(--color-gray-light); cursor: pointer;">
                <i data-lucide="x" style="width: 20px; height: 20px;"></i>
            </button>
        </div>
        
        <!-- Whiteboard Toolbar -->
        <div style="padding: 0.5rem 1rem; background: var(--color-black); border-bottom: 1px solid var(--color-gray-mid); display: flex; gap: 1rem; align-items: center;">
            <div style="display: flex; gap: 0.5rem;">
                <button class="wb-tool active" data-tool="pen" style="background: var(--color-primary); color: black; border: none; padding: 0.25rem 0.5rem; border-radius: 4px; cursor: pointer; display: flex; align-items: center; gap: 5px;" title="Pen">
                    <i data-lucide="edit-3" style="width: 16px;"></i> Pen
                </button>
                <button class="wb-tool" data-tool="eraser" style="background: rgba(0,0,0,0.1); color: var(--color-white); border: none; padding: 0.25rem 0.5rem; border-radius: 4px; cursor: pointer; display: flex; align-items: center; gap: 5px;" title="Eraser">
                    <i data-lucide="eraser" style="width: 16px;"></i> Eraser
                </button>
            </div>
            
            <div style="width: 1px; height: 20px; background: var(--color-gray-mid);"></div>
            
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <input type="color" id="wbColor" value="#00e5ff" style="cursor: pointer; width: 30px; height: 30px; border: none; border-radius: 50%; overflow: hidden; padding: 0; background: transparent;">
                <input type="range" id="wbSize" min="1" max="20" value="3" style="width: 80px; cursor: pointer;">
            </div>
            
            <div style="flex: 1;"></div>
            
            <div style="display: flex; gap: 0.5rem;">
                <button onclick="clearWhiteboard()" style="background: rgba(0,0,0,0.1); color: var(--color-white); border: none; padding: 0.25rem 0.5rem; border-radius: 4px; cursor: pointer;" title="Clear All">
                    <i data-lucide="trash-2" style="width: 16px;"></i>
                </button>
                <button onclick="downloadWhiteboard()" style="background: rgba(0,0,0,0.1); color: var(--color-white); border: none; padding: 0.25rem 0.5rem; border-radius: 4px; cursor: pointer;" title="Download as Image">
                    <i data-lucide="download" style="width: 16px;"></i>
                </button>
            </div>
        </div>

        <!-- Canvas Container -->
        <div style="flex: 1; position: relative; background: #FFFFFF; cursor: crosshair;" id="wbCanvasContainer">
            <canvas id="wbCanvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; touch-action: none;"></canvas>
        </div>
    </div>

    <script>
        lucide.createIcons();
        const courseId = '<%= course.id %>';

        // --- Tabs Logic ---
        function switchTab(tabName) {
            const tabs = ['overview', 'qna', 'ai', 'notes', 'resources', 'announcements'];
            
            tabs.forEach(tab => {
                const tabEl = document.getElementById(`tab-${tab}`);
                const btnEl = document.getElementById(`btn-${tab}`);
                
                if (tabEl) {
                    tabEl.style.display = tabName === tab ? 'block' : 'none';
                }
                
                if (btnEl) {
                    btnEl.style.color = tabName === tab ? 'var(--color-primary)' : 'var(--color-gray-light)';
                    btnEl.style.borderBottom = tabName === tab ? '2px solid var(--color-primary)' : 'none';
                }
            });
        }

        // --- QnA Logic ---
        async function loadQnA() {
            const res = await fetch(`/api/v1/courses/${courseId}/qna`);
            const data = await res.json();
            const container = document.getElementById('qnaList');
            if(data.success && data.data.length > 0) {
                container.innerHTML = data.data.map(q => `
                    <div style="background: rgba(0,0,0,0.02); padding: 1rem; border-radius: 4px; margin-bottom: 1rem; border: 1px solid var(--color-gray-mid);">
                        <strong style="color: var(--color-white);">${q.user.name}</strong>
                        <p style="color: var(--color-gray-light); margin-top: 0.5rem;">${q.question}</p>
                    </div>
                `).join('');
            } else {
                container.innerHTML = '<p style="color: var(--color-gray-light);">No questions yet. Be the first to ask!</p>';
            }
        }

        document.getElementById('qnaForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const question = document.getElementById('qnaQuestion').value;
            const res = await fetch(`/api/v1/courses/qna`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ courseId, question })
            });
            if((await res.json()).success) {
                document.getElementById('qnaQuestion').value = '';
                loadQnA();
            }
        });

        // --- Whiteboard Logic ---
        const wbPanel = document.getElementById('whiteboardPanel');
        const wbHeader = document.getElementById('whiteboardHeader');
        const wbCanvas = document.getElementById('wbCanvas');
        const wbCtx = wbCanvas ? wbCanvas.getContext('2d') : null;
        let isDrawing = false;
        let currentTool = 'pen';
        let currentColor = '#00e5ff';
        let currentSize = 3;

        function toggleWhiteboard() {
            if (wbPanel.style.display === 'none') {
                wbPanel.style.display = 'flex';
                initWhiteboard();
            } else {
                wbPanel.style.display = 'none';
            }
        }

        function initWhiteboard() {
            const container = document.getElementById('wbCanvasContainer');
            wbCanvas.width = container.clientWidth;
            wbCanvas.height = container.clientHeight;
            wbCtx.lineCap = 'round';
            wbCtx.lineJoin = 'round';
            
            // Set default background (dark)
            wbCtx.fillStyle = '#1a1a1a';
            wbCtx.fillRect(0, 0, wbCanvas.width, wbCanvas.height);
        }

        if (wbCanvas) {
            wbCanvas.addEventListener('mousedown', startDrawing);
            wbCanvas.addEventListener('mousemove', draw);
            wbCanvas.addEventListener('mouseup', stopDrawing);
            wbCanvas.addEventListener('mouseout', stopDrawing);

            // Touch support
            wbCanvas.addEventListener('touchstart', (e) => {
                e.preventDefault();
                const touch = e.touches[0];
                const mouseEvent = new MouseEvent('mousedown', {
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                wbCanvas.dispatchEvent(mouseEvent);
            }, { passive: false });

            wbCanvas.addEventListener('touchmove', (e) => {
                e.preventDefault();
                const touch = e.touches[0];
                const mouseEvent = new MouseEvent('mousemove', {
                    clientX: touch.clientX,
                    clientY: touch.clientY
                });
                wbCanvas.dispatchEvent(mouseEvent);
            }, { passive: false });

            wbCanvas.addEventListener('touchend', (e) => {
                const mouseEvent = new MouseEvent('mouseup', {});
                wbCanvas.dispatchEvent(mouseEvent);
            });
        }

        function getMousePos(canvas, evt) {
            const rect = canvas.getBoundingClientRect();
            return {
                x: evt.clientX - rect.left,
                y: evt.clientY - rect.top
            };
        }

        function startDrawing(e) {
            isDrawing = true;
            const pos = getMousePos(wbCanvas, e);
            wbCtx.beginPath();
            wbCtx.moveTo(pos.x, pos.y);
            
            wbCtx.strokeStyle = currentTool === 'eraser' ? '#1a1a1a' : currentColor;
            wbCtx.lineWidth = currentTool === 'eraser' ? currentSize * 4 : currentSize;
        }

        function draw(e) {
            if (!isDrawing) return;
            const pos = getMousePos(wbCanvas, e);
            wbCtx.lineTo(pos.x, pos.y);
            wbCtx.stroke();
        }

        function stopDrawing() {
            isDrawing = false;
        }

        function clearWhiteboard() {
            if (confirm('Clear the entire whiteboard?')) {
                wbCtx.fillStyle = '#1a1a1a';
                wbCtx.fillRect(0, 0, wbCanvas.width, wbCanvas.height);
            }
        }

        function downloadWhiteboard() {
            const link = document.createElement('a');
            link.download = `Whiteboard_${new Date().toISOString().split('T')[0]}.png`;
            link.href = wbCanvas.toDataURL();
            link.click();
        }

        // Toolbar Tools
        document.querySelectorAll('.wb-tool').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelectorAll('.wb-tool').forEach(b => {
                    b.classList.remove('active');
                    b.style.background = 'rgba(0,0,0,0.1)';
                    b.style.color = 'white';
                });
                const target = e.currentTarget;
                target.classList.add('active');
                target.style.background = 'var(--color-primary)';
                target.style.color = 'black';
                currentTool = target.dataset.tool;
            });
        });

        document.getElementById('wbColor')?.addEventListener('input', (e) => {
            currentColor = e.target.value;
            if(currentTool === 'eraser') {
                document.querySelector('.wb-tool[data-tool="pen"]').click();
            }
        });

        document.getElementById('wbSize')?.addEventListener('input', (e) => {
            currentSize = parseInt(e.target.value);
        });

        // Make draggable
        let isDraggingWb = false;
        let wbOffset = { x: 0, y: 0 };

        wbHeader?.addEventListener('mousedown', (e) => {
            isDraggingWb = true;
            wbOffset = {
                x: e.clientX - wbPanel.getBoundingClientRect().left,
                y: e.clientY - wbPanel.getBoundingClientRect().top
            };
            wbHeader.style.cursor = 'grabbing';
        });

        document.addEventListener('mousemove', (e) => {
            if (!isDraggingWb) return;
            
            // Constrain to window
            let newX = e.clientX - wbOffset.x;
            let newY = e.clientY - wbOffset.y;
            
            const maxW = window.innerWidth - wbPanel.offsetWidth;
            const maxH = window.innerHeight - wbPanel.offsetHeight;
            
            newX = Math.max(0, Math.min(newX, maxW));
            newY = Math.max(0, Math.min(newY, maxH));
            
            wbPanel.style.left = newX + 'px';
            wbPanel.style.top = newY + 'px';
            // Remove right property since we are using left
            wbPanel.style.right = 'auto';
        });

        document.addEventListener('mouseup', () => {
            isDraggingWb = false;
            if(wbHeader) wbHeader.style.cursor = 'grab';
        });

        // --- AI Tutor Logic ---
        document.getElementById('aiChatForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const inputField = document.getElementById('aiQuestionInput');
            const submitBtn = document.getElementById('aiSubmitBtn');
            const chatWindow = document.getElementById('aiChatWindow');
            const question = inputField.value.trim();

            if (!question) return;

            // Append User Question
            const userBubble = document.createElement('div');
            userBubble.style.cssText = 'align-self: flex-end; background: var(--color-primary); padding: 0.75rem 1rem; border-radius: 8px; border-bottom-right-radius: 0; color: var(--color-black); font-weight: 500; max-width: 80%;';
            userBubble.innerText = question;
            chatWindow.appendChild(userBubble);
            chatWindow.scrollTop = chatWindow.scrollHeight;

            inputField.value = '';
            inputField.disabled = true;
            submitBtn.disabled = true;
            submitBtn.innerText = '...';

            try {
                const res = await fetch('/api/v1/ai/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        courseId: courseId,
                        lessonId: '<%= activeLesson ? activeLesson.id : "" %>',
                        question: question
                    })
                });

                const data = await res.json();

                const aiBubble = document.createElement('div');
                aiBubble.style.cssText = 'align-self: flex-start; background: rgba(0,0,0,0.1); padding: 0.75rem 1rem; border-radius: 8px; border-bottom-left-radius: 0; color: var(--color-white); max-width: 80%; line-height: 1.5;';
                
                if (data.success) {
                    // Simple formatting for markdown logic just replacing newlines for now
                    aiBubble.innerHTML = data.reply.replace(/\n/g, '<br>');
                } else {
                    aiBubble.style.color = '#ff4d4f';
                    aiBubble.innerText = 'Error: ' + data.message;
                }
                
                chatWindow.appendChild(aiBubble);
                chatWindow.scrollTop = chatWindow.scrollHeight;

            } catch (err) {
                const errorBubble = document.createElement('div');
                errorBubble.style.cssText = 'align-self: flex-start; background: rgba(255,77,79,0.1); color: #ff4d4f; padding: 0.75rem 1rem; border-radius: 8px; border-bottom-left-radius: 0; max-width: 80%;';
                errorBubble.innerText = 'Network error contacting AI Tutor.';
                chatWindow.appendChild(errorBubble);
                chatWindow.scrollTop = chatWindow.scrollHeight;
            } finally {
                inputField.disabled = false;
                submitBtn.disabled = false;
                submitBtn.innerText = 'Send';
                inputField.focus();
            }
        });

        // --- Rating Modal Logic ---
        const reviewModal = document.getElementById('reviewModal');
        const stars = document.querySelectorAll('#starRating i');
        const ratingInput = document.getElementById('ratingInput');

        function openReviewModal() {
            reviewModal.style.display = 'flex';
        }
        function closeReviewModal() {
            reviewModal.style.display = 'none';
        }

        stars.forEach(star => {
            star.addEventListener('click', (e) => {
                const rating = parseInt(e.currentTarget.getAttribute('data-rating'));
                ratingInput.value = rating;
                updateStarVisuals(rating);
            });
            star.addEventListener('mouseover', (e) => {
                updateStarVisuals(parseInt(e.currentTarget.getAttribute('data-rating')), true);
            });
            star.addEventListener('mouseout', () => {
                updateStarVisuals(parseInt(ratingInput.value));
            });
        });

        function updateStarVisuals(rating, isHover = false) {
            stars.forEach((star, idx) => {
                if (idx < rating) {
                    star.style.color = 'var(--color-primary)';
                    star.style.fill = isHover ? 'none' : 'var(--color-primary)';
                } else {
                    star.style.color = 'var(--color-gray-mid)';
                    star.style.fill = 'none';
                }
            });
        }

        document.getElementById('reviewForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const rating = ratingInput.value;
            const review = document.getElementById('reviewTextInput').value;

            if (rating == 0) return alert('Please select a star rating.');

            const btn = document.getElementById('submitReviewBtn');
            btn.disabled = true;
            btn.innerText = 'Submitting...';

            try {
                const res = await fetch(`/api/v1/courses/${courseId}/rate`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ rating, review })
                });
                const data = await res.json();
                if (data.success) {
                    closeReviewModal();
                    alert('Thank you for your review!');
                } else {
                    alert(data.message || 'Error submitting review');
                }
            } catch (err) {
                alert('Connection error');
            } finally {
                btn.disabled = false;
                btn.innerText = 'Submit Review';
            }
        });

        // Advanced Dynamic Watermark Anti-Piracy
        (function () {
            const email = '<%= typeof user !== "undefined" ? user.email : "learner@example.com" %>';
            const videoContainer = document.querySelector('.video-container');
            let watermark = null;

            function createWatermark() {
                if (watermark) watermark.remove();
                watermark = document.createElement('div');
                watermark.id = 'wm-anti-piracy';
                videoContainer.appendChild(watermark);
                updateWatermarkText();
                moveWatermark();
            }

            function updateWatermarkText() {
                if (!watermark) return;
                const time = new Date().toISOString().split('T')[1].split('.')[0];
                watermark.innerText = `${email} - ${time}`;
            }

            function moveWatermark() {
                if (!watermark) return;
                const containerW = videoContainer.clientWidth;
                const containerH = videoContainer.clientHeight;
                // Keep within bounds roughly
                const maxLeft = Math.max(10, containerW - 250);
                const maxTop = Math.max(10, containerH - 30);

                watermark.style.left = Math.floor(Math.random() * maxLeft) + 'px';
                watermark.style.top = Math.floor(Math.random() * maxTop) + 'px';
            }

            createWatermark();

            // Update text every second, move every 10 seconds
            setInterval(updateWatermarkText, 1000);
            setInterval(moveWatermark, 10000);
    const assignForm = document.getElementById('assignmentSubmitForm');
    if (assignForm) {
        assignForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = assignForm.querySelector('button');
            const fileInput = document.getElementById('assignFile');
            const assignId = document.getElementById('assignId').value;
            
            if (!fileInput.files[0]) {
                return alert('Please select a file to upload.');
            }

            btn.disabled = true;
            btn.innerText = 'Uploading...';

            try {
                // Upload logic simulation or actual
                const formData = new FormData();
                formData.append('file', fileInput.files[0]);

                const uploadRes = await fetch('/api/v1/upload', {
                    method: 'POST',
                    body: formData
                });
                const uploadData = await uploadRes.json();
                
                if (!uploadData.success) {
                    throw new Error(uploadData.message || 'Upload failed');
                }

                const submitRes = await fetch('/api/v1/courses/assignments/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ assignmentId: assignId, fileUrl: uploadData.url })
                });
                const submitData = await submitRes.json();
                
                if (submitData.success) {
                    window.location.reload();
                } else {
                    throw new Error(submitData.message || 'Submission failed');
                }
            } catch (error) {
                alert(error.message);
                btn.disabled = false;
                btn.innerText = 'Submit Assignment';
            }
        });
    }
            // Tamper Protection (MutationObserver)
            // If the user tries to delete the watermark or hide it via DevTools, we recreate it.
            const observer = new MutationObserver((mutations) => {
                let tampered = false;
                mutations.forEach((mutation) => {
                    if (mutation.type === 'childList') {
                        mutation.removedNodes.forEach((node) => {
                            if (node.id === 'wm-anti-piracy') tampered = true;
                        });
                    } else if (mutation.type === 'attributes' && mutation.target.id === 'wm-anti-piracy') {
                        // Check if they tried to hide it via CSS
                        const style = window.getComputedStyle(watermark);
                        if (style.display === 'none' || style.opacity === '0' || style.visibility === 'hidden') {
                            tampered = true;
                        }
                    }
                });

                if (tampered) {
                    console.warn("Security Event: Watermark tampering detected. Logging out...");
                    fetch('/api/v1/auth/logout', { method: 'POST' }).then(() => {
                        window.location.href = '/login?error=tampering_detected';
                    });
                }
            });

            observer.observe(videoContainer, { childList: true, subtree: true, attributes: true });

            // Ensure fullscreen uses the container, not just the video element, so watermark stays visible
            document.addEventListener('fullscreenchange', () => {
                if (document.fullscreenElement === videoContainer) {
                    moveWatermark();
                }
            });

            // Detect Keyboard Shortcuts for Screen Recording/Screenshots
            document.addEventListener('keydown', (e) => {
                let isRecordingShortcut = false;

                // Print Screen key
                if (e.key === 'PrintScreen') isRecordingShortcut = true;

                // Windows Snipping Tool / Mac Screenshots
                if ((e.metaKey || e.ctrlKey) && e.shiftKey) {
                    if (e.key === 'S' || e.key === 's' || e.key === '3' || e.key === '4' || e.key === '5') {
                        isRecordingShortcut = true;
                    }
                }

                // Windows Game Bar Record (Win + Alt + R)
                if (e.metaKey && e.altKey && (e.key === 'r' || e.key === 'R')) {
                    isRecordingShortcut = true;
                }

                if (isRecordingShortcut) {
                    e.preventDefault();
                    console.warn("Security Event: Recording/Screenshot shortcut detected. Logging out...");
                    fetch('/api/v1/auth/logout', { method: 'POST' }).then(() => {
                        window.location.href = '/login?error=recording_detected';
                    });
                }
            });
        })();

        // Progress Tracking
        async function markLessonComplete(lessonId) {
            try {
                const res = await fetch(`/student/courses/${courseId}/progress`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lessonId })
                });
                const data = await res.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert('Error marking complete');
                }
            } catch (err) {
                console.error(err);
            }
        }

        // Module Completion Logic
        const markCompleteBtn = document.getElementById('markCompleteBtn');
        if (markCompleteBtn) {
            // In a production environment with Video.js, this would be:
            // player.on('ended', function() { markCompleteBtn.style.display = 'block'; });
            
            // Simulating video completion after 5 seconds for demonstration
            setTimeout(() => {
                markCompleteBtn.style.display = 'block';
            }, 5000);

            // Simulating watched seconds tracking
            let watchedSeconds = 0;
            setInterval(() => {
                watchedSeconds += 5;
                fetch(`/student/courses/${courseId}/progress`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lessonId: '<%= activeLesson ? activeLesson.id : "" %>', watchedSeconds })
                }).catch(e => console.error(e));
            }, 5000);
        }
    </script>
</body>

