<div class="card" style="padding: 2rem; max-width: 600px; margin: 0 auto;">
    <h2 style="font-family: var(--font-heading); margin-bottom: 2rem;">My Profile</h2>

    <div style="display: flex; align-items: center; gap: 2rem; margin-bottom: 2rem;">
        <div style="width: 100px; height: 100px; border-radius: 50%; background: var(--color-gray-dark); overflow: hidden; border: 2px solid var(--color-primary);">
            <img id="avatarPreview" src="<%= user.avatar || '/images/default-avatar.png' %>" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <div>
            <h3 style="margin-bottom: 0.5rem;"><%= user.name %></h3>
            <p class="text-muted" style="margin-bottom: 0.5rem;"><%= user.email %></p>
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                <i data-lucide="award" class="text-primary" style="width: 18px;"></i>
                <span style="font-family: var(--font-heading); font-weight: 600; color: var(--color-primary);"><%= user.totalPoints || 0 %> XP</span>
            </div>
            <label class="btn btn-outline" style="cursor: pointer;">
                Change Picture
                <input type="file" id="avatarInput" accept="image/*" style="display: none;">
            </label>
        </div>
    </div>

    <form id="profileForm">
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label style="display: block; margin-bottom: 0.5rem; color: var(--color-gray-light);">Full Name</label>
            <input type="text" id="nameInput" value="<%= user.name %>" style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid var(--glass-border); color: var(--color-white); padding: 0.75rem; border-radius: 8px;" required>
        </div>

        <button type="submit" class="btn btn-primary" id="saveBtn">Save Changes</button>
        <p id="message" style="margin-top: 1rem;"></p>
    </form>
</div>

<div class="card" style="padding: 2rem; max-width: 600px; margin: 2rem auto;">
    <h3 style="font-family: var(--font-heading); margin-bottom: 1.5rem;">Change Password</h3>
    <form id="passwordForm">
        <div class="form-group" style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; color: var(--color-gray-light);">Current Password</label>
            <input type="password" id="currentPassword" style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid var(--glass-border); color: var(--color-white); padding: 0.75rem; border-radius: 8px;" required>
        </div>
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label style="display: block; margin-bottom: 0.5rem; color: var(--color-gray-light);">New Password</label>
            <input type="password" id="newPassword" style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid var(--glass-border); color: var(--color-white); padding: 0.75rem; border-radius: 8px;" required>
        </div>

        <button type="submit" class="btn btn-outline" id="pwdSaveBtn">Update Password</button>
        <p id="pwdMessage" style="margin-top: 1rem;"></p>
    </form>
</div>

<script>
    const avatarInput = document.getElementById('avatarInput');
    const avatarPreview = document.getElementById('avatarPreview');
    let selectedFile = null;

    avatarInput.addEventListener('change', function(e) {
        if(e.target.files && e.target.files[0]) {
            selectedFile = e.target.files[0];
            const reader = new FileReader();
            reader.onload = function(e) {
                avatarPreview.src = e.target.result;
            }
            reader.readAsDataURL(selectedFile);
        }
    });

    document.getElementById('profileForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('saveBtn');
        const msg = document.getElementById('message');
        
        btn.disabled = true;
        btn.innerText = 'Saving...';
        msg.textContent = '';

        const formData = new FormData();
        formData.append('name', document.getElementById('nameInput').value);
        if (selectedFile) {
            formData.append('avatar', selectedFile);
        }

        try {
            const res = await fetch('/api/v1/auth/profile', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if (data.success) {
                msg.textContent = 'Profile updated successfully!';
                msg.style.color = 'var(--color-success)';
            } else {
                msg.textContent = data.message;
                msg.style.color = 'var(--color-danger)';
            }
        } catch (err) {
            msg.textContent = 'Connection error';
            msg.style.color = 'var(--color-danger)';
        } finally {
            btn.disabled = false;
            btn.innerText = 'Save Changes';
        }
    });

    document.getElementById('passwordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('pwdSaveBtn');
        const msg = document.getElementById('pwdMessage');
        const currentPassword = document.getElementById('currentPassword').value;
        const newPassword = document.getElementById('newPassword').value;

        btn.disabled = true;
        btn.innerText = 'Updating...';
        msg.textContent = '';

        try {
            const res = await fetch('/api/v1/auth/profile/password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ currentPassword, newPassword })
            });
            const data = await res.json();
            if (data.success) {
                msg.textContent = 'Password updated successfully!';
                msg.style.color = 'var(--color-success)';
                document.getElementById('passwordForm').reset();
            } else {
                msg.textContent = data.message;
                msg.style.color = 'var(--color-danger)';
            }
        } catch (err) {
            msg.textContent = 'Connection error';
            msg.style.color = 'var(--color-danger)';
        } finally {
            btn.disabled = false;
            btn.innerText = 'Update Password';
        }
    });
</script>
