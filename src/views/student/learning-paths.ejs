<div class="header-banner" style="background: var(--color-bg); padding: 2rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid var(--color-gray-mid);">
    <h1 style="font-family: var(--font-display); margin: 0; color: var(--color-text);">Learning Paths</h1>
    <p style="color: var(--color-gray-light); margin-top: 0.5rem;">Follow a structured curriculum designed to take you from beginner to expert.</p>
</div>

<% if (paths.length === 0) { %>
    <div class="card" style="padding: 3rem; text-align: center;">
        <i data-lucide="route" style="width: 48px; height: 48px; color: var(--color-gray-mid); margin-bottom: 1rem;"></i>
        <h3 style="color: var(--color-gray-light);">No Learning Paths Available</h3>
        <p class="text-muted">Instructors have not created any structured learning paths yet.</p>
    </div>
<% } else { %>
    <div style="display: flex; flex-direction: column; gap: 2rem;">
        <% paths.forEach(path => { %>
            <div class="card" style="padding: 2rem;">
                <h2 style="font-family: var(--font-display); color: var(--color-primary); margin-bottom: 0.5rem;"><%= path.title %></h2>
                <p style="color: var(--color-gray-light); margin-bottom: 2rem;"><%= path.description %></p>
                
                <div style="position: relative; padding-left: 2rem; border-left: 2px dashed var(--color-gray-mid);">
                    <% path.courses.forEach((course, idx) => { %>
                        <div style="position: relative; margin-bottom: 2rem;">
                            <!-- Node Indicator -->
                            <div style="position: absolute; left: -2.75rem; top: 0; background: var(--color-card); border: 2px solid <%= course.percentComplete >= 100 ? 'var(--color-success)' : 'var(--color-primary)' %>; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                <% if (course.percentComplete >= 100) { %>
                                    <i data-lucide="check" style="width: 14px; color: var(--color-success);"></i>
                                <% } else { %>
                                    <span style="font-size: 0.75rem; font-weight: bold; color: var(--color-text);"><%= idx + 1 %></span>
                                <% } %>
                            </div>

                            <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--color-gray-mid); padding: 1.5rem; border-radius: 8px; display: flex; align-items: flex-start; gap: 1.5rem;">
                                <% if (course.thumbnailUrl) { %>
                                    <img src="<%= course.thumbnailUrl %>" alt="<%= course.title %>" style="width: 150px; height: 100px; object-fit: cover; border-radius: 4px;">
                                <% } else { %>
                                    <div style="width: 150px; height: 100px; background: var(--color-bg); display: flex; align-items: center; justify-content: center; border-radius: 4px;">
                                        <i data-lucide="book-open" style="color: var(--color-gray-mid);"></i>
                                    </div>
                                <% } %>

                                <div style="flex: 1;">
                                    <h3 style="margin-bottom: 0.5rem;"><a href="/courses/<%= course.slug %>" style="color: var(--color-text); text-decoration: none;"><%= course.title %></a></h3>
                                    <p style="color: var(--color-gray-light); font-size: 0.9rem; margin-bottom: 1rem;"><%= course.description.substring(0, 100) %>...</p>
                                    
                                    <!-- Progress Bar -->
                                    <div style="width: 100%; height: 6px; background: var(--color-gray-mid); border-radius: 3px; overflow: hidden; margin-bottom: 0.5rem;">
                                        <div style="width: <%= course.percentComplete %>%; height: 100%; background: <%= course.percentComplete >= 100 ? 'var(--color-success)' : 'var(--color-primary)' %>;"></div>
                                    </div>
                                    <small style="color: var(--color-gray-light);"><%= Math.round(course.percentComplete) %>% Complete</small>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>

<script>
    lucide.createIcons();
</script>
