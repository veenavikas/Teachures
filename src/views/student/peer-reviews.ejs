<div class="grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
    <!-- Pending Reviews -->
    <div class="card" style="padding: 2rem;">
        <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem;">Pending Reviews</h3>
        
        <% if (pendingReviews.length === 0) { %>
            <p class="text-muted">You have no pending peer reviews.</p>
        <% } else { %>
            <div style="display: grid; gap: 1rem;">
                <% pendingReviews.forEach(review => { %>
                    <div style="border: 1px solid var(--color-gray-mid); border-radius: 8px; padding: 1.5rem;">
                        <h4 style="margin-bottom: 0.5rem;"><%= review.submission.assignment.title %></h4>
                        <p style="color: var(--color-gray-light); font-size: 0.9rem; margin-bottom: 1rem;">
                            Course: <%= review.submission.assignment.lesson.section.course.title %>
                        </p>
                        
                        <a href="<%= review.submission.fileUrl %>" target="_blank" class="btn btn-outline" style="margin-bottom: 1rem; display: inline-block;">View Submission</a>
                        
                        <form class="peer-review-form" data-review-id="<%= review.id %>">
                            <div class="form-group" style="margin-bottom: 1rem;">
                                <label class="form-label">Grade (0-100)</label>
                                <input type="number" name="grade" class="form-control" min="0" max="100" required>
                            </div>
                            <div class="form-group" style="margin-bottom: 1rem;">
                                <label class="form-label">Feedback</label>
                                <textarea name="feedback" class="form-control" rows="3" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%;">Submit Review</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <!-- Completed Reviews -->
    <div class="card" style="padding: 2rem;">
        <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--color-gray-mid); padding-bottom: 1rem;">Completed Reviews</h3>
        
        <% if (completedReviews.length === 0) { %>
            <p class="text-muted">You have not completed any peer reviews yet.</p>
        <% } else { %>
            <div style="display: grid; gap: 1rem;">
                <% completedReviews.forEach(review => { %>
                    <div style="border: 1px solid var(--color-gray-mid); border-radius: 8px; padding: 1.5rem; background: rgba(0,0,0,0.02);">
                        <h4 style="margin-bottom: 0.5rem;"><%= review.submission.assignment.title %></h4>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <span class="badge" style="background: rgba(var(--color-success-rgb), 0.2); color: var(--color-success);">Grade Given: <%= review.grade %>%</span>
                        </div>
                        <p style="color: var(--color-gray-light); font-size: 0.9rem; margin: 0; white-space: pre-wrap;"><%= review.feedback %></p>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<script>
document.querySelectorAll('.peer-review-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const reviewId = form.getAttribute('data-review-id');
        const grade = form.grade.value;
        const feedback = form.feedback.value;

        try {
            const res = await fetch(`/student/peer-reviews/${reviewId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ grade, feedback })
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                alert('Failed to submit review: ' + data.message);
            }
        } catch(err) {
            alert('Server error');
        }
    });
});
</script>
